<script>
  window.addEventListener(
    'DOMContentLoaded', startRetentionEngine('https://web.archive.org/web/20230205214637/https://app.bellwethr.com/offboard/experience/kinder-beauty-box')
  );

  const generateRetentionEngineLink = (subscription_ids_array) => {
    return RELinkGenerator('https://web.archive.org/web/20230205214637/https://app.bellwethr.com/offboard/experience/kinder-beauty-box', subscription_ids_array);
  };
</script>

<script>
  (function() {
    var loadScript = function(url, callback){
      var script = document.createElement('SCRIPT');
      script.src = url;
      script.type = 'text/javascript';
      script.onload = function() { callback(window.jQuery) };
      document.getElementsByTagName('head')[0].appendChild(script);
    };

    var loadRetentionEngine = function($){
   function checkSubscriptionsPage() {
    $(".rc_subscriptions__subscription__item").each(function() {
    if ($(this).find(".rc_subscriptions__subscription__item__cancel > a").length) {
     let oldHref = $(this).find(".rc_subscriptions__subscription__item__cancel > a")[0].href;
     let subscriptionId = oldHref.match(new RegExp('subscriptions/' + "(.*)" + '/cancel'))[1];
     $(this).find(".rc_subscriptions__subscription__item__cancel > a")[0].href = "https://web.archive.org/web/20230205214637/https://app.bellwethr.com/offboard/experience/kinder-beauty-box?subscription_id=" + subscriptionId;
   }})}

   function checkEditPage() {
    if ($("#rc_subscriptions__items__cancel > a").length) {
     let oldHref = $("#rc_subscriptions__items__cancel > a")[0].href;
     let subscriptionId = oldHref.match(new RegExp('subscriptions/' + "(.*)" + '/cancel'))[1];
     $("#rc_subscriptions__items__cancel > a")[0].href = "https://web.archive.org/web/20230205214637/https://app.bellwethr.com/offboard/experience/kinder-beauty-box?subscription_id=" + subscriptionId;
    }}

    function checkNovum() {
      let cancelBtn = $('.rc_cancel-btn')[0];
      if (cancelBtn != undefined) { 
        cancelBtn.removeEventListener("click", cancelSubscriptionFlow);
        let subscriptionId = $(cancelBtn).data('id');
        let link = "https://web.archive.org/web/20230205214637/https://app.bellwethr.com/offboard/experience/kinder-beauty-box?subscription_id=" + subscriptionId;
        let linkHtml = `<a href=${link}></a>`;
        $(cancelBtn).wrap(linkHtml);
      }
    }

   function checkRechargePlusPage() {
     let query = $('a').filter(function (index) {
       return $(this).text().toUpperCase().trim() === 'Cancel My Subscription'.toUpperCase() ||
         $(this).text().toUpperCase().trim() === 'Cancel Subscription'.toUpperCase();
     });
     if (query.length) {
       const rechargeData = query.data('rcData');
       let subscriptionId;
       if (rechargeData) {
         subscriptionId = rechargeData['subscription_id'];
       } else {
         let oldHref = query[0].href;
         subscriptionId = oldHref.match(new RegExp('subscriptions/' + '(.*)' + '/cancel'))[1];
       }
       let newHref = "https://web.archive.org/web/20230205214637/https://app.bellwethr.com/offboard/experience/kinder-beauty-box?subscription_id=" + subscriptionId;
       query[0].href = newHref;
       query.attr('data-rc-modal', 'disable');
     }
   }

    checkSubscriptionsPage();
    checkRechargePlusPage();
    checkEditPage();
    checkNovum();
    }

    if ((typeof jQuery === 'undefined') || (parseFloat(jQuery.fn.jquery) < 1.7)) {
      loadScript('//web.archive.org/web/20230205214637/https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js', function(jq){
        const jQueryInstance = jq.noConflict(true);
        loadRetentionEngine(jQueryInstance);
      });
    } else {
      loadRetentionEngine(jQuery);
    }

  })();
</script>

