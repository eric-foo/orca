            clearTimeout(timeoutId);
            timeoutId = setTimeout(function () {
              return fn.apply(_this, args);
            }, ms);
          };
        };

        // adjust header offset on screen resize
        window.addEventListener('resize', debounce(function() {
          var element = $('#shopify-section-announcement-bar .notification-bar');
          var root = document.documentElement;
          
          var currentOffset = getComputedStyle(root).getPropertyValue('--announcement-bar-offset');
          var updatedOffset = element.outerHeight() + "px";
          
          if (currentOffset !== updatedOffset) {
