  --color-scheme-accent-text-hover: rgba(255, 255, 255, 0.7);
  --color-scheme-accent-input-hover: rgba(255, 255, 255, 0.1);

  --color-scheme-dark-background: #242424;
  --color-scheme-dark-background-hover: rgba(36, 36, 36, 0.1);
  --color-scheme-dark-text: #ffffff;
  --color-scheme-dark-text-hover: rgba(255, 255, 255, 0.7);
  --color-scheme-dark-input-hover: rgba(255, 255, 255, 0.1);

  --header-font-stack: 'P22 Underground', sans-serif;

  --header-font-weight: 400;
  --header-font-style: normal;
  --header-font-transform: uppercase;

  --header-font-script-stack: 'blackjack', sans-serif;
  --header-font-script-weight: 400;
  --header-font-script-style: 'normal';
  --header-font-script-transform: 'none';

  --header-font-condensed-stack: 'Bebas Neue', sans-serif;
