<script>
  $('button.slide-menu-mobile').click(function(e){
    $('#slideout-overlay').css('display','block');
    $('#main-body').css({'position': 'fixed', 'margin-top': '0px', 'transform': 'translateX(300px)'});
    $('#theme-menu').removeClass('slideout-panel-hidden');
  })

  $('button.mobile-menu-close').click(function(){
    $('#slideout-overlay').removeAttr('style');
    $('#main-body').removeAttr('style');
    $('#theme-menu').addClass('slideout-panel-hidden');
  })
  $('main-body').click(function(){
    $('#slideout-overlay').removeAttr('style');
    $('#main-body').removeAttr('style');
    $('#theme-menu').addClass('slideout-panel-hidden');
  })

  $('button.slide-menu-cart').click(function(e){
    e.stopPropagation();
    e.preventDefault();
    document.location.href = '/cart';
  })
 
</script>

