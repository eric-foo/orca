  --select-radius: 2px !default;

  --border-color: rgba(34, 34, 34, 0.5);
  --border-search: rgba(34, 34, 34, 0.1);
  --border-color-subtle: rgba(34, 34, 34, 0.1);
  --border-color-subtle-darken: #151515;

