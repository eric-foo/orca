          var ms = arguments.length <= 1 || arguments[1] === undefined ? 0 : arguments[1];
          var timeoutId = void 0;
          return function () {
            var _this = this;
            for (var _len = arguments.length, args = Array(_len), _key = 0; _key < _len; _key++) { 
