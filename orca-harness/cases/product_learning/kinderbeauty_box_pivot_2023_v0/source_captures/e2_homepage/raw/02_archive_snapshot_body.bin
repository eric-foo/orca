  }

  @keyframes shopTheLookDotKeyframe {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 #ffffff;
      opacity: 0.7;
    }
    70% {
      transform: scale(1);
      box-shadow: 0 0 0 10px #ffffff;
      opacity: 0;
    }
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 #ffffff;
      opacity: 0;
    }
  }

  .stl__dot,
  .stl__dot-num {
    background-color: #ffffff;
  }
</style>


