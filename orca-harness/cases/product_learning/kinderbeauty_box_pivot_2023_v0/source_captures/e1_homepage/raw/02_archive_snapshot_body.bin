  <script>
    // Cheat to open the cart after 1 second, so it has time to send the request to shopify and when we open the cart to refresh it.
    document.addEventListener('click', e => {
      const { target } = e;

      if (target.matches('.js-go-cart-add-to-cart')) {
        setTimeout(() => {
          document.dispatchEvent(new Event('theme:cart_drawer_open_request'))
        }, 1000)
      }
    })

    // Some pages are not using the .js-go-cart-add-to-cart, so listening to the form submit
    document.querySelectorAll('[action="/cart/add"]').forEach(form => {
      form.addEventListener('click', e => {
        const { target } = e;

        if (target.matches('[type="submit"]')) {
          setTimeout(() => {
            document.dispatchEvent(new Event('theme:cart_drawer_open_request'))
          }, 1000)
        }
      })
    })
  </script>

