                    <div class="search__brands">
                        
<svg width="20" height="20" viewbox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M8.74975 16.8749C10.6915 16.8752 12.5685 16.1764 14.0372 14.9062L17.8497 18.7187C17.9015 18.7916 17.9683 18.8525 18.0457 18.8973C18.123 18.9422 18.2091 18.9699 18.298 18.9786C18.387 18.9874 18.4768 18.977 18.5614 18.948C18.646 18.9191 18.7234 18.8724 18.7884 18.811C18.8533 18.7496 18.9044 18.675 18.9381 18.5922C18.9718 18.5094 18.9873 18.4204 18.9837 18.3311C18.98 18.2417 18.9573 18.1543 18.9169 18.0745C18.8765 17.9947 18.8195 17.9245 18.7497 17.8687L14.9372 14.0562C16.1471 12.6532 16.8412 10.879 16.9045 9.02747C16.9677 7.17598 16.3964 5.35847 15.2851 3.87621C14.1738 2.39395 12.5894 1.33596 10.7944 0.877608C8.99944 0.419261 7.10173 0.588085 5.41585 1.35609C3.72998 2.1241 2.35718 3.44518 1.52502 5.10033C0.692867 6.75548 0.451323 8.64531 0.84043 10.4566C1.22954 12.2678 2.22593 13.8917 3.66444 15.059C5.10295 16.2264 6.89719 16.8671 8.74975 16.8749ZM8.74975 1.87493C10.1095 1.87493 11.4387 2.27814 12.5693 3.03358C13.6999 3.78901 14.5811 4.86274 15.1014 6.11898C15.6218 7.37523 15.7579 8.75756 15.4926 10.0912C15.2274 11.4248 14.5726 12.6498 13.6111 13.6113C12.6496 14.5728 11.4246 15.2276 10.091 15.4928C8.75737 15.7581 7.37504 15.622 6.1188 15.1016C4.86256 14.5813 3.78883 13.7001 3.03339 12.5695C2.27796 11.4389 1.87475 10.1097 1.87475 8.74993C1.87475 6.92657 2.59908 5.17789 3.88839 3.88857C5.1777 2.59926 6.92638 1.87493 8.74975 1.87493Z" fill="#B3ADAD"/>
</svg>
    
                        <input type="text" id="myInput" onkeyup="myFunction()" placeholder="Search FAQs">
                    </div>
    
                    <h3 class="faq__heading" data-shipping="Shipping &amp; Return FAQs" data-general="General FAQs" data-account="My Account FAQs" data-membership="Membership FAQs"></h3>
                    <div class="faq__wrapper general">
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>What is Kinder Beauty Box?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Kinder Beauty Box is an activist-founded cruelty-free, vegan, and clean beauty box, on a mission to make the world a kinder place for animals, for people, and for the planet. Each monthly box is packed with at least $85 worth of hand-picked cosmetics, skincare, hair care products, accessories &amp; more!</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Are all the products really vegan and cruelty-free?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Absolutely, yes! Our three founders are all long-time vegan and animal activists, who personally ensure that each chosen product goes through a strict vetting process to guarantee that every product we send your way has not been tested on animals and doesn't contain any nasty animal ingredients or byproducts.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>I hate waste! What steps has Kinder Beauty taken to help protect the environment?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>We hate waste, too! That’s why we’ve taken earth-friendly steps we hope you’ll appreciate. For starters, our box is made from 100% recycled materials and is both biodegradable and compostable. The packing materials inside the box are also made from 100% recycled materials, and the ink used to print our logo and designs on the outside of the box, is an eco-friendly soy-based ink. Pretty cool, right?!  <br><br>In terms of the individual product packaging, many of the brands we work with use only eco-friendly materials. However, not every brand is quite there yet. We hope consumers will join us in urging more brands to switch over to using only eco-friendly packaging.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Did I hear that Kinder Beauty donates a portion of proceeds to charity each month?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Yes! Every month a portion of proceeds goes to various animal rights and environmental causes. Kinder Beauty has supported organizations such as ASPCA, Farm Sanctuary, Los Angeles County Animal Care Foundation, Catskills Animal Sanctuary, and Compassion Over Killing, to name just a few.</p></div>
                                    </div>
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                        <a href="/web/20230205211216/https://kinderbeauty.com/pages/customer-help#contact-us" class="custom__button contact_btn">Contact us</a>
                    </div>
                    <div class="faq__wrapper account">
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How do I reactivate my account?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>  
                                        </h3>
                                        <div class="accordion__body"><p>To reactivate your account, please log in, click on “Subscriptions,” and then click on “Re-activate.”</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How do I Choose My Box?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>  
                                        </h3>
                                        <div class="accordion__body"><p>If you are a 6-month subscriber - or - a subscriber who has been active for 6+ months, you have the ability to Choose Your Box!</p><p><a href="https://web.archive.org/web/20230205211216/https://kinderbeauty.com/pages/choose-your-box" target="_blank">Click here for detailed directions.</a></p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How do I Skip a box?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>  
                                        </h3>
                                        <div class="accordion__body"><p>For <strong>monthly subscribers</strong>, please see the <a href="https://web.archive.org/web/20230205211216/https://kinderbeauty.com/pages/skip-a-box" target="_blank">instructions here</a> on how to skip your box.</p><p>For 6- and 12-month subscribers, kindly reach out to our Customer Support folks at <a href="https://web.archive.org/web/20230205211216/mailto:support@kinderbeauty.com" target="_blank" title="mailto:support@kinderbeauty.com">support@kinderbeauty.com</a> for assistance.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How do I update my payment information?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>  
                                        </h3>
                                        <div class="accordion__body"><p>Please log into your account and click on “Billing information” on the left side of the page.</p> <p>Once you’ve accessed your billing screen, you’ll be able to update your billing method, shipping address, and email.</p> <p>If you need to update the email address on file, please log into your account, click on “Billing Information,” and then click on “Edit” under your email address.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How do I update my mailing address?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>  
                                        </h3>
                                        <div class="accordion__body"><p>If you have a new address, please let us know. We’ll update all of your shipping information for you.</p></div>
                                    </div>
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                        <a href="/web/20230205211216/https://kinderbeauty.com/pages/customer-help#contact-us" class="custom__button contact_btn">Contact us</a>
                    </div>
                    <div class="faq__wrapper shipping">
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>What’s your refund/return policy?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>We will do our best to resolve every issue that pops up. It’s important to us that we take care of you. If there’s something in your box that arrives damaged – or something that just doesn’t work for you, please let us know (support@kinderbeauty.com). There’s no need to return the damaged or defective product – we’ll ship a replacement to you for free!</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How can I track my box?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>To track your Beauty Box, you will be sent an email containing a tracking number once it has left our warehouse!</p><p>Please keep in mind that it can take up to 10 business days for package to be delivered to domestic customers from the day your box leaves our warehouse. For international packages to be delivered, it can take up to 4 weeks from the day your box leaves our warehouse, depending on the time it takes to clear customs.</p><p>You can track your packages <a href="https://web.archive.org/web/20230205211216/https://kinderbeauty.com/pages/tracking" target="_blank">here</a>.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>What countries do you ship to?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>We ship to the following countries: Australia,Austria, Belgium, Canada, Denmark, Estonia, Finland, France, Germany, Hong Kong,Ireland, Israel, Italy, Japan, Netherlands, New Zealand, Philippines, Poland, Portugal, Romania, Singapore, Spain, Sweden, Switzerland, United Kingdom, Unites States</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Something in my box was missing or damaged.</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Please reach out to us right away! We’ll ship you a replacement on our very next truck.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>What is a carbon neutral order and how does it work?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Because taking care of our planet is always on our mind, we’ve partnered with EcoCart to offer sustainable shipping options at checkout. By donating, you’ll be helping to remove ocean plastic pollution, reducing reliance on burning fossil fuels, and providing cleaner oceans! Here’s how it works:</p><p><strong>Step 1:</strong> Shop from any Subscription Plan or from our Marketplace.</p><p><strong>Step 2:</strong> EcoCart’s built-in algorithm determines the exact cost of offsetting the pollution from manufacturing and shipping for all items in your cart.</p><p><strong>Step 3:</strong> Toggle the EcoCart box to ON to make your order carbon-neutral, adding about 1-2% to your total order.</p><p><strong>Step 4:</strong> Pay for your order and pollution offsets, and sleep tight knowing your new beauty products are carbon neutral and helping to tackle the plastic crisis!</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Why was there this Carbon Neutral Order Product added to my cart?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>When you click the checkbox to make your order carbon neutral, EcoCart adds a product to your cart in order to increase your cart total so we can fund certain carbon offset projects. It is not a physical product, and won’t show up in your order when you receive it, but you will receive information about your impact through email!</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Why did you choose to partner with EcoCart and TONTOTON?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>As a member of the beauty community, we know the impact our industry can have on waste, especially when it comes to plastic pollution. That’s why we work hard to partner with vendors and brands who go above and beyond for you and the planet. Our partnership with EcoCart and TONTOTON allows us to make an impact on ocean clean-up and plastic pollution.</p><p>To learn more about ocean plastic pollution and how you can help, visit our <a href="https://web.archive.org/web/20230205211216/https://kinderbeauty.com/blogs/kinder-articles/sustainable-shipping-ecocart-partnership" target="_blank">Blog</a>. </p></div>
                                    </div>
                            
                        
                        <a href="/web/20230205211216/https://kinderbeauty.com/pages/customer-help#contact-us" class="custom__button contact_btn">Contact us</a>
                    </div>
                    <div class="faq__wrapper membership">
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How does a Kinder Beauty Box subscription work?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Choose any of our subscription plans (Monthly, 6-Month, or 12-Month) and your first monthly box will ship within 7-10 days. Each month we’ll start billing you* for your monthly shipments on the 8th of each month and ship your package out of our warehouse between the 9th and the 15th of the month. You’ll receive a shipping confirmation email once your box leaves the warehouse.  <br/><br/><em>*If you are signed up for a 6-Month or 12-Month planned, you'll only be billed again at the end of your term.</em></p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How much does Kinder Beauty Box cost?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Our Monthly subscription plan costs just $26 per month.</p><p>If you commit to a 6-Month ($138) or 12-Month ($276) plan, you pay upfront, but the “per box” rate is discounted to $23/box.</p><p>Shipping is free for US customers. For international customers, there is an additional $9.99 per box fee for shipping and handling.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>When will I be billed for my Kinder Beauty Box?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>You’ll be billed on the day you first sign up for KBB – and then on the 8th of the month, every month thereafter.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>What payment methods do you accept?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>For Subscription purchases, we currently accept Visa, Mastercard, American Express, Discover, and PayPal.</p><p>For Marketplace purchases, we currently accept Visa, Mastercard, American Express, Discover, PayPal, ShopPay, Google Pay, and Facebook Pay.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>When will you ship my first Beauty Box order?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Your first monthly box will ship within 7-10 days. You’ll receive an email confirmation with tracking info as soon as your order ships.</p><p>If you've purchased from our Marketplace, those orders ship within a few days of your purchase.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Can I sign up for just one Beauty Box box?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Unfortunately, we do not currently have an option to buy just one Beauty Box in our subscription offerings. However, we do occasionally offer past boxes for purchase in our Marketplace which is a great way to test the waters and see how great our boxes are! They are limited and always go fast so make sure you’re signed up for our emails so you know as soon as we add past boxes to the Marketplace!</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Is it easy to cancel my subscription?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>It’s super easy, though we’ll hate to see you go! Your Kinder Beauty subscription can be canceled by logging into your account and going to the subscription tab under your name. There will be an option under Action that will allow you to cancel your subscription. </p><p>That’s it! No need to call or e-mail anyone, once you cancel your subscription you won’t be billed again. Though you will still receive any boxes for which you’ve already paid.</p><p>If you’re having trouble doing so, please write in to our Customer Support (support@kinderbeauty.com) team before the 8th (for Beauty Box) or the 20th (for KND Box) of the month to avoid auto-renewal.</p><p>However, our Marketplace orders get processed right away -- so if you need to cancel, please write in within an hour from the time you have placed your order.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Can I purchase Kinder Beauty products without a subscription?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Yes, you can! We have a Marketplace that's open to members and non-members where you can purchase individual items. Products range from items that have been features in our boxes, special bundles, and the occasional recent monthly box—all at Kinder prices. We add new "drops" in the Marketplace regularly, but the fan favorites always go fast, so make sure you sign up for our email list so you never miss a drop!</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>What are my Beauty Box gifting options?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>We offer <em>non-recurring</em> 3-month, 6-month, and 12-month Beauty Box gift subscription plans. </p><p>The gift recipient will receive a monthly box for the duration of their gift plan subscription, starting with the featured box in the month it was purchased.</p><p>(We are currently not offering gift cards.)</p><p>To purchase a gift subscription, please click <a href="/web/20230205211216/https://kinderbeauty.com/pages/gift-kinder-beauty" target="_blank" title="Gift Kinder Beauty">here</a> and choose the plan option you would like to gift. Once purchased, the gift recipient will receive their first beauty box within 7-10 days (USA).</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>What is the KND Box?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>A curated lifestyle box chocked full of vegan, cruelty-free, clean products.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Is the KND Box connected to my Kinder Beauty Box Subscription?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>No. The KND box is a separate subscription service.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How is the KND Box different than the Kinder Beauty Box?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>A bigger box means more fun stuff inside. The products you’ll find in the KND box are a little less beauty-centric and designed to support an overall cleaner lifestyle. Additionally, the KND box is delivered on a quarterly basis instead of a monthly basis.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>How often would I receive the KND Box?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>KND boxes are shipped quarterly. So, 4x a year—which is why the KND box has a higher price tag than our beauty box.</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>Can I buy a KND Box without a subscription?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>Yes, you can! You can make a one-time purchase or shop around in our Marketplace. Products range from special features from our boxes, special bundles, and the occasional recent monthly box—all at Kinder prices. We add new "drops" in the Marketplace regularly, but the fan favorites always go fast, so make sure you sign up for our email list so you never miss a drop!</p></div>
                                    </div>
                            
                        
                            
                                    <div class="accordion__wrapper">
                                        <h3 class="accordion__heading">
                                            <span>What countries do you ship the KND Box to?</span>
                                            <div class="acordion__icon">
                                                <span class="plus">
<svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.24982 14V7.75H-0.000183105V6.25H6.24982V0H7.74982V6.25H13.9998V7.75H7.74982V14H6.24982Z" fill="#2B2424"/>
  </svg>
  </span>
                                                <span class="minus">
<svg width="14" height="14" viewbox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6.31218 1.6875H0.583008V0.3125H6.31218H7.68718H13.4163V1.6875H7.68718H6.31218Z" fill="#2B2424"/>
  </svg>
  </span>
                                            </div>
                                        </h3>
                                        <div class="accordion__body"><p>We are currently shipping the KND Box to the United States, Canada, France, Germany, Poland, Portugal, Sweden, and the United Kingdom.</p></div>
                                    </div>
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                            
                        
                        <a href="/web/20230205211216/https://kinderbeauty.com/pages/customer-help#contact-us" class="custom__button contact_btn">Contact us</a>
                    </div>
                </div>
    
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function(){
        let navigation = document.querySelectorAll('.help__wrapper__inner nav a')
        let content__wrapper = document.querySelectorAll('.help__content')    

        setTimeout(function(){
            checkCurrentNav()
        }, 0)
        
        navigation.forEach(item => {
            item.addEventListener('click', function(){
                setTimeout(function(){
                    checkCurrentNav()
                }, 0)
            })
        })

        function checkCurrentNav(){
            let url = document.location.href
            let id = url.substring(url.lastIndexOf('#') + 1);

            if(url.lastIndexOf('#') != -1){
                navigation.forEach(item => {
                    item.classList.remove('active')
                })
    
                navigation.forEach(item => {
                    if(item.href.lastIndexOf(id) != -1){
                        item.classList.add('active')
                    }
                })
            }else{
                navigation[0].classList.add('active')
            }

            document.querySelectorAll('.faq__wrapper').forEach(item => [
                item.classList.remove('active__faq')
            ])

            content__wrapper.forEach(item => {
                item.classList.remove('active')
            })

            let actveLink = document.querySelector('.help__wrapper__inner nav .active').href

            if(actveLink.lastIndexOf('contact-us') != -1){
                content__wrapper[0].classList.add('active')
            }else{
                let currentTab = actveLink.substring(actveLink.lastIndexOf('#') + 1);
                document.querySelector('.faq__heading').innerHTML = document.querySelector('.faq__heading').dataset[currentTab]
                content__wrapper[1].classList.add('active')
                document.querySelector(`.faq__wrapper.${currentTab}`).classList.add('active__faq')
            }
        }
        
        document.querySelectorAll('.accordion__heading').forEach(item => {
            item.addEventListener('click', function(){
                this.classList.toggle('active')
            })
        })
        let contact = document.querySelector('[data-link="Contact"]')
        document.querySelectorAll('.contact_btn').forEach(item => {
            item.addEventListener('click', function(e){
                e.preventDefault()
                contact.click()
            })
        })
    })
    function myFunction() {
        // Declare variables
        var input, filter, ul, li, a, i, txtValue;
        input = document.getElementById('myInput');
        filter = input.value.toUpperCase();
        document.querySelectorAll('.accordion__wrapper').forEach(item => {
            let a = item.querySelector('.accordion__heading span')
            txtValue = a.textContent || a.innerText;
            if (txtValue.toUpperCase().indexOf(filter) > -1) {
                item.style.display = "";
                // item.closest('.filter__wrapper').classList.remove('none')
            } else {
                item.style.display = "none";
                // item.closest('.filter__wrapper').classList.add('none')
            }
        })
    }

    
</script>


</div>
