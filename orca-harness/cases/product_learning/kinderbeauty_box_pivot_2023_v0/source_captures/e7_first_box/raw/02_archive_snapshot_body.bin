                    <div class="block__text__wrapper">
                        <h2 class="block__heading">
                            <p>The world has changed. So should <strong>your beauty routine!</strong></p>
                            
                            <svg width="330" height="14" viewbox="0 0 330 14" fill="none" xmlns="http://www.w3.org/2000/svg" style="position: absolute;">
                                <g clip-path="url(#clip0_434_16439)">
                                <path d="M2.34961 4.5471C14.6842 3.84537 34.8513 2.23791 47.8112 1.91108C83.9055 0.997878 111.457 2.74703 111.457 2.74703C129.59 3.52566 160.851 4.55366 166.762 8.23529C174.266 12.8975 161.478 12.4902 155.019 11.5294C131.885 8.0881 150.959 2.42054 172.047 1.91107C212.405 0.940198 289.398 2.80506 327.652 4.84294" stroke="#D18E57" stroke-width="4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
