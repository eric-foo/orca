                                <defs>
                                <clippath id="clip0_434_16439">
                                <rect width="330" height="14" fill="white"/>
                                </clippath>
                                </defs>
                                </svg>
    
                        </h2>
                        <div class="block__description">We created Kinder Beauty Box to help take the guesswork out of discovering beauty products that are better for your skin, animals, and the environment.</div>
                        <a href="#select-a-plan" class="custom__button">Get the Box</a>
                    </div>
                </section>
            
            
                <section class="imgtext">
                    <div class="block__text__wrapper">
                        <h2 class="block__heading"><p>Why Subscribe to Kinder Beauty Box?</p></h2>
                        <div class="steps__wrapper">
                            <div class="step">
                                <span class="step__number">1</span>
                                <span class="step__info"><strong>You shop, we give back.</strong> We've donated $100,000+ to charities that protect animals.</span>
                            </div>
                            <div class="step">
                                <span class="step__number">2</span>
                                <span class="step__info"><strong>The reviews are in!</strong> More than 2,500 ⭐⭐⭐⭐⭐ reviews and counting.</span>
                            </div>
                            <div class="step">
                                <span class="step__number">3</span>
                                <span class="step__info"><strong>We support small businesses.</strong> Discover skincare, makeup, and hair products from top up-and-coming brands.</span>
                            </div>
                            <div class="step">
                                <span class="step__number">4</span>
                                <span class="step__info"><strong>Flexible subscriptions.</strong> Easily cancel, skip a box, or upgrade your subscription at any time.</span>
                            </div>
                        </div>
                        <a href="#select-a-plan" class="custom__button">Get the box</a>
                    </div>
                    <div class="image__wrapper">
                        <img loading="lazy" src="//web.archive.org/web/20221208115319im_/https://cdn.shopify.com/s/files/1/0118/0631/0459/files/Frame_592_9.png?v=1662969965" alt="">
                    </div>
                </section>
            

        </div>
