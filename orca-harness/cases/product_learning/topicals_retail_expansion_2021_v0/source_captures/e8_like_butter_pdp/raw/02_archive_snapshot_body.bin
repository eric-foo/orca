    if($(this).hasClass('qtyplus')) {
      qty++;
    }else {
      if(qty > 1) {
        qty--;
      }
    }
    qty = (isNaN(qty))?1:qty;
  
    $('.qtybox_2').find('.quantity-input').val(qty);
  }); 
  
  
