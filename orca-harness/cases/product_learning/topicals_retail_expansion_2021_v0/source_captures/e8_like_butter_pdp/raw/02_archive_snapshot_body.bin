<script>
$(document).ready(function() {
  
 $('.itchy_mobile').click(function(){
   if ($(".itchy_fm_div").hasClass("hide_spoti")){ 
    $('#spotify_player').addClass('show');
    $('.itchy_fm_div').removeClass('hide_spoti'); 
    $('.itchy_fm_div').addClass('show');
      
     
   }else
   {
    $('#spotify_player').removeClass('show');
    $('.itchy_fm_div').addClass('hide_spoti'); 
    $('.itchy_fm_div').removeClass('show');  
     
   }
 });
  
 $('.spotify_close').click(function(){
   $('#spotify_player').removeClass('show');
    $('.itchy_fm_div').addClass('hide_spoti'); 
    $('.itchy_fm_div').removeClass('show');  
  });  
   
  
  
