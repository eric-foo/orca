  overflow: hidden;
  max-height: 600px;
}

.slow-image-zoom-on-hover{
  overflow: hidden;
  max-height: 600px;
} 

.slow-image-zoom-on-hover img{ 
  transition: scale(1.1);
  transition: transform 5s;
}

.slow-image-zoom-on-hover:hover img{
  transform: scale(1.5);
  transition: transform 5s;
}
</style></div></div></div><div class="rewards--row text-block section--padding-top--double section--padding-bottom--double" data-content-type="row" data-appearance="full-width" data-enable-parallax="0" data-parallax-speed="0.5" data-background-images="{}" data-background-type="image" data-video-loop="true" data-video-play-only-visible="true" data-video-lazy-load="true" data-video-fallback-src="" data-element="main" data-pb-style="L8KS1NU"><div class="row-full-width-inner" data-element="inner"><div data-content-type="html" data-appearance="default" data-element="main" data-decoded="true"><style>
