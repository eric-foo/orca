<script type="text/javascript">
requirejs([
    'jquery',
], function($) {

$(document).ready(function() {

    console.clear()

const navExpand = [].slice.call(document.querySelectorAll('.nav-expand'))
const backLink = `<li class="nav-item">
	<a class="nav-link nav-back-link" href="javascript:;">
		All
	</a>
</li>`

navExpand.forEach(item => {
	item.querySelector('.nav-expand-content').insertAdjacentHTML('afterbegin', backLink)
	item.querySelector('.nav-link').addEventListener('click', () => item.classList.add('active'))
	item.querySelector('.nav-back-link').addEventListener('click', () => item.classList.remove('active'))
})


// ---------------------------------------
// not-so-important stuff starts here

const ham = document.getElementById('ham')
ham.addEventListener('click', function() {
	document.body.classList.toggle('nav-is-toggled')
})


/****
**
** Search Bar Toggle
**
****/


const search = document.querySelector('.block-search')
search.addEventListener('click', function(event) {
    //event.stopPropagation();
    //alert(event.target.classList);

    if( event.target.classList == "block block-search" ){ // Added here /IF protection
        document.querySelector('.block .block-content').classList.toggle('open')
    }

})





/****
**
** MegaMenu Blur Hover Effect
**
****/


$(".kiss-menu-mega, .kiss-menu-mega-shop").on('hover',function(){
	  $('.page-header').removeClass('animate__animated animate__slideOutUp');
	  $('.page-header').removeClass('animate__animated animate__slideInDown');
      $(".header.content").addClass('blur');

 });

 $(".kiss-menu-mega, .kiss-menu-mega-shop").on('mouseleave',function(){
      $(".header.content").removeClass('blur');

 });



/****
 * $('body').hasClass('nav-is-toggled')
 * scroll magic show
 */

		function hasClass(element, cls) {
                 return (' ' + element.className + ' ').indexOf(' ' + cls + ' ') > -1;
               }

		var lastScrollTop = 50;


		$(window).scroll(function(event){


                var el = document.getElementsByTagName('body')[0];
               if(!hasClass(el, 'nav-is-toggled')){/// if mobile menu open dont get work to animation.


		var st = $(this).scrollTop();

		//console.log(st);

        if(st > 150){

		if (st > lastScrollTop){
			// downscroll code

			$('.page-header').removeClass('animate__animated animate__slideInDown');
			$('.page-header').addClass('animate__animated animate__slideOutUp');

		} else {
			// upscroll code
			$('.page-header').removeClass('animate__animated animate__slideOutUp');
			$('.page-header').addClass('animate__animated animate__slideInDown');
			}
		lastScrollTop = st;

    }

               } /// en if has class

      });






});

    // document ready tag. end
});

</script>
