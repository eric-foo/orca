    width: 200px;
  }
</style></div><div data-content-type="html" data-appearance="default" data-element="main" data-decoded="true"><!-- Spacing -->
<style>
:root{
  --spacing: min(20px,4vw);
  --double-spacing: calc( 2 * var(--spacing) );
  --half-spacing: calc( .5 * var(--spacing) );
  --quater-spacing: calc( .25 * var(--spacing) );
}

@media screen and (min-width: 768px){
  :root{
    --spacing: 2.25vw;
  }
}

.section--padding-top{           padding-top: var(--spacing); }
.section--padding-bottom{        padding-bottom: var(--spacing); }
.section--margin-top{            margin-top: var(--spacing); }
.section--margin-bottom{         margin-bottom: var(--spacing); }

.section--padding-top--half{     padding-top: var(--half-spacing); } 
.section--padding-bottom--half{  padding-bottom: var(--half-spacing); } 
.section--margin-top--half{      margin-top: var(--half-spacing); } 
.section--margin-bottom--half{   margin-bottom: var(--half-spacing); } 

.section--padding-top--quater{     padding-top: var(--quater-spacing); } 
.section--padding-bottom--quater{  padding-bottom: var(--quater-spacing); } 
.section--margin-top--quater{      margin-top: var(--quater-spacing); } 
.section--margin-bottom--quater{   margin-bottom: var(--quater-spacing); } 

.section--padding-top--double{   padding-top: var(--double-spacing); } 
.section--padding-bottom--double{padding-bottom: var(--double-spacing); } 
.section--margin-top--double{    margin-top: var(--double-spacing); } 
.section--margin-bottom--double{ margin-bottom: var(--double-spacing); } 


@media screen and (max-width: 767px){
  .section--no-padding-top--mobile{           padding-top: 0; }
  .section--no-padding-bottom--mobile{        padding-bottom: 0 }
  .section--no-margin-top--mobile{            margin-top: 0}
  .section--no-margin-bottom--mobile{         margin-bottom: 0 }
}

</style></div><div data-content-type="html" data-appearance="default" data-element="main" data-pb-style="IHQC0B4" data-decoded="true"><!-- Default Text -->
<style>

strong{
  font-weight: bold;
}

main h1, main h2, main h3, main h4, main h5, main h6{
  font-size: 24px;
  margin: 0;
  padding: 0;
  margin-top: 1em; 
  font-family: "Poppins";
}


main p, main li{
    font-size: 16px;
    margin: 0;
    padding: 0;
    padding-top: 1em; 
}

main li{
    padding-top: .5em;
}

main ul, main ol{
    margin: 0;
    padding: 0;
    margin-left: 4em;
}

main a{
    color: #000;
    text-decoration: underline;
}

main a:hover{
    text-decoration: none;
    color: #000;
}
</style></div><div data-content-type="html" data-appearance="default" data-element="main" data-decoded="true"><!-- Text Blocks -->
<style>
:root{
  --fluid-text-size: clamp(15px, 5vw, 20px);
  --text-block-size: min(5.2vw, 16px);
}

@media screen and (min-width: 768px){
  :root{ 
    --fluid-text-size: clamp(15px, 1.36vw, 20px);
  }
}

.text-block{
    //font-size: var(--fluid-text-size);
    font-size: var(--text-block-size);
    color: #000; 
}

.text-block h2, .text-block h3, .text-block p{
    margin-top: 0;
    margin-bottom: 0;
    padding-top: 0;
    padding-bottom: 0;
    color: inherit;
    font-weight: normal;
}

.text-block strong{  font-weight: bold; } 
.text-block h2{   font-size: 1.625em;  }
 
.text-block h3{
    font-weight: bold;
}
.text-block h3,
.text-block p{
    font-size: 1em;
    margin-top: .35em;
}

.text-block h2 + h3{ margin-top: 0; }
.text-block h2 + p{ margin-top: 1em; }

.text-block p + p{
    margin-top: 1em;
}

.text-block h3{ font-size: 1.25em }

.text-block a{
    font-size: 1em;
}


</style></div><div data-content-type="html" data-appearance="default" data-element="main" data-decoded="true"><!-- Text Colors -->
<style>
  .pink-heading h2{
    color: #e19fa5;
  }

  
  .pink-text{
        color: #d38c8f;
  }

  .hot-pink-text, .hot-pink-text h2,  .hot-pink-text h3,  .hot-pink-text p, .hot-pink-text a{
        color: var(--joah-hot-pink);
  }

  .green-text{
    color: #2dcc70;
  }
  .yellow-text{
      color: #ffae00;
  }
  .red-text{
    color: #e64c3d;
  }
</style></div><div data-content-type="html" data-appearance="default" data-element="main" data-decoded="true"><!-- Capsule Button -->
<style>
.capsule-button--pink a,
.capsule-button--white a,
.capsule-button a{
    
    border-radius: 2em;
    display: block;
    color: #fff;
    background: #000;
    border: 1px solid #000;
    font-size: 14px;
    padding: .9em 1.75em;
    max-width: 22em;
    font-weight: 400;
    text-align: center;
    letter-spacing: .05em;
    text-decoration: none;
    line-height: 1;
}

@media screen and (min-width: 768px){
    .capsule-button a {
        display: inline-block;
        max-width: none;
    }
