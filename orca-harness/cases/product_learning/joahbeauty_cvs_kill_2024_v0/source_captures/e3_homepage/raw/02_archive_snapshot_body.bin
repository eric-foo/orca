<style>
.toggle-carousel-buttons{ 
    display: flex;
    justify-content: center;
    font-size: 12px;
    margin-left: auto;
    margin-right: auto;
    max-width: 40em;
    align-items: center; 
    margin-bottom: 2em;
}

.toggle-carousel-buttons button,
.toggle-carousel-buttons a{
    background: none; 
    padding: 1em .8em;
    border:  none;
    text-transform: uppercase;
    color: #000;
    font-weight: 700;
    font-size: 1em;
    text-decoration: none;
    text-align: center;
    margin: 0;
    position: relative;
}


@media screen and (min-width: 768px){
  .toggle-carousel-buttons{ 
    font-size: max(1.2vw, 16px); 
  } 
  .toggle-carousel-buttons button,
  .toggle-carousel-buttons a{
    padding: 1em 1.5em;
  }
}


.toggle-carousel-buttons button:hover,
.toggle-carousel-buttons a:hover,
.toggle-carousel-buttons button.active-button{ 
    color: #000;
    color: var(--joah-hot-pink);
}

.toggle-carousel-buttons button.active-button:after{
    display: block;
    height: .2em; 
    width: 80%;
    background: #000;
    background: var(--joah-hot-pink);
    content: " ";
    left: 50%;
    transform: translateX(-50%);
    position: absolute;
    bottom: .5em;

}

</style></div><div data-content-type="html" data-appearance="default" data-element="main" data-decoded="true"><!-- Carousel Css -->
<style>
    body {
        overflow-x: hidden;  
    }
 
  
    .product-item-details {
        padding: 20px;
    }
  
    .product-item-info {
        box-sizing: border-box; 
        width: 100%;
    }

    .product-carousel-wrapper .product-item-details,
    .product-carousel-wrapper .product-item-info{
        background-color: #fff;
    }

    

   .css-product-carousel-wrapper {
        //position: fixed;
        transform: translateY(-1000vh);
        height: 0; 
        //top: -1000vw;
        //left: -1000vw;
    }


    .css-product-carousel-wrapper.active-carousel {
        position: static;
        top: 0;
        left: 0; 
        transform: translateY(0);
        height: auto;
    }

    .product-carousel .owl-nav {
      display: flex;
      justify-content: center;
      padding-top: 10px; 
    }
    </style></div><div data-content-type="html" data-appearance="default" data-element="main" data-decoded="true"><!-- Carousel Css That Should Be In Less Files Once They Are Compiling -->
