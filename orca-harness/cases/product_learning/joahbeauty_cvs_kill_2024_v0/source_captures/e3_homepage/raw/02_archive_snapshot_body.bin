</style></div><div data-content-type="html" data-appearance="default" data-element="main" data-decoded="true"><!-- Page Banner Text -->
<style>
.page-banner--text{
    text-align: center;
    display: flex;
    justify-content: center;
    flex-flow: column; 
    padding-left: 20px;
    padding-right: 20px; 
    font-size: 4vw;
    font-size: min(5vw, 20px); 
}

 .page-banner-row  .pagebuilder-column-line{
    height: 100%;
}  

.page-banner--text h1,
.page-banner--text h2, 
.page-banner--text p{
  margin-top: 0;
  margin-bottom: 0;
  padding-top: 0;
  padding-bottom: 0;
}


[data-content-type$='block'] .block .page-banner--text p:last-child{
  margin-bottom: 0!important;
  margin-top: 1em;
}

[data-content-type$='block'] .block .page-banner--text-desktop p:last-child{
  margin-bottom: -1em!important;
  margin-top: 1em;
}

.page-banner--text h1,
.page-banner--text h2{
    font-weight: normal;
    font-size: 1.3em; 
}

.black-text-m h1,
.black-text-m h2,
.black-text-m p{
  color: #000;
}


.page-banner--text p{
    font-size: .76em;
    margin-top: 1em;
}
.page-banner--text-desktop p{
    font-size: .80em;
    margin-top: 0em;
}
.page-banner--text-desktop h1{
    font-size: 1.6em;
    margin-top: 0em;
}
.page-banner--text a{
    margin-top: 1em;
}

