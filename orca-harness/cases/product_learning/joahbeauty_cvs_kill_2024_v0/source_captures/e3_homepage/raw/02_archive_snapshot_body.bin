</style></div></div></div><div class="special-message-row" data-content-type="row" data-appearance="full-width" data-enable-parallax="0" data-parallax-speed="0.5" data-background-images="{}" data-background-type="image" data-video-loop="true" data-video-play-only-visible="true" data-video-lazy-load="true" data-video-fallback-src="" data-element="main" data-pb-style="LF3NKKC"><div class="row-full-width-inner" data-element="inner"><div data-content-type="html" data-appearance="default" data-element="main" data-decoded="true"><style>
	.fadding-messages{  
		font-size: 9px;
		padding: 1em 0;
		position: relative;
                
	}

	@media screen and (min-width: 450px){
		.fadding-messages{ 
			font-size: 14px;
		}
	}

	.fadding-messages div{
		opacity: 0 ;
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%,-50%);
		text-align: center;
		white-space: nowrap;
		font-weight: 500;
	}

        .fadding-messages .message{ opacity: 1; } 

        @media screen and (max-width:  767px){
		.fadding-messages div{
			white-space: normal;
			width:  100%;
			max-width: 350px;
		}
	}

 
	
 	.message1{ animation: textFadeIn1 16s infinite; }
 	.message2{ animation: textFadeIn2 16s infinite; }
 	.message3{ animation: textFadeIn3 16s infinite; }
 	.message4{ animation: textFadeIn4 16s infinite; }

	@keyframes textFadeIn1{
	      0% { opacity: 0; }
	      1% { opacity: 1; }
	     50% { opacity: 1; }
	     51% { opacity: 0; } 
	    100% { opacity: 0; }
	}

	@keyframes textFadeIn2{
	      0% { opacity: 0; } 
	     50% { opacity: 0; }
	     51% { opacity: 1; } 
	    99%  { opacity: 1; }  
	    100% { opacity: 0; }   
	}



</style>

