<script>

    require(['jquery','owl-carousel/owl.carousel'], function($) {

    	let i = 0;

	    let myInterval = setInterval(
	    	function(){
	    		checkIfElementExists(".ai-owl-carousel", i);
	    		i++;
	    	}, 500
	    );

	 	function checkIfElementExists(e, i){
	    	let ele = document.querySelector(e);
			if(ele){
				// console.log(`Element ${e} exists after ${i} seconds.`);
				initalizeCarousel();
				clearInterval(myInterval); 
			}
			if(i > 15){
				// console.log(`Stopped checking for ${e} after ${i} seconds.`);
				clearInterval(myInterval); 
			}
			if(!ele){
				// console.log(`Element ${e} doesn't exist.`); 
			}
	    }

    	function initalizeCarousel(){
            $('.ai-owl-carousel').owlCarousel({
                loop: false,
                nav: true,
                margin: 10,
                dots: false,
                navText : ["<i class='fa fa-chevron-left'></i>","<i class='fa fa-chevron-right'></i>"],
                responsive:{
                    0:{ items: 1 },
                    768:{ items: 3 },
                    990:{  items: 4  } 
                }
            }); 
    	}

    });

</script>
