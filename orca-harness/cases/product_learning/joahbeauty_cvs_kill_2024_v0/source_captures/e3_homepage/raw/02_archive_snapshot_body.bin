<script type="text/javascript">
requirejs([
    'jquery',
], function($) {
    window.onload = function(){
        window.dataLayer = window.dataLayer || [];
        
        let addCart = document.querySelectorAll('form button.tocart, form[data-role="tocart-form"] button.action');
        for(var i = 0; i < addCart.length; i++) {
            addCart[i].addEventListener("click", function(e) {
                var parent = e.currentTarget.parentNode;

                while(parent.querySelector('input[name="product"]') == null) {
                    parent = parent.parentNode;
                }

                var quantity = 1;
                qtyTag = parent.querySelector('input[name="qty"]')
                if ( qtyTag !== null) {
                    quantity = qtyTag.value;
                }

                var productId = parent.querySelector('input[name="product"]').value;

                var selectProduct = document.querySelector('.product-options-wrapper .swatch-attribute');

                if(selectProduct != null) {
                    productId = selectProduct.getAttribute('product-id');
                } else {
                    // Get selected child product
                    form_action = parent.getAttribute('action');
                    form_action = form_action.split("/");

                    if(form_action[form_action.length - 2] != null) {
                        productId = form_action[form_action.length - 2];
                    }
                }

                var url = 'https://web.archive.org/web/20230407022305/https://www.joahbeauty.com/googledata/data/addtocart' + '/product/' + productId + '/quantity/' + quantity;

                if(productId != null) {
                    var apiResponse = fetch(url,{
                        method: 'GET',
                        mode: 'cors',
                        cache: 'default',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    })
                    .then(response => response.text())
                    .then(data => {
                        dataObj = JSON.parse(data);
                        dataObj.data = JSON.parse(dataObj.data);
                        dataObj.data["page_type"] = "testing";
                        if ($("body.catalog-product-view").length > 0) {
                            dataObj.data["page_type"] = "product_detail";
                        } else if ($("body.catalog-category-view").length > 0) {
                            dataObj.data["page_type"] = "category";
                        } else if (window.location.pathname == '/') {
                            dataObj.data["page_type"] = "home_page";
                        } else {
                            dataObj.data["page_type"] = "landing_page";
                        }

                        dataObj.data = JSON.stringify(dataObj.data);
                        window.dataLayer.push(JSON.parse(dataObj.data));
                    })
                    .catch(error => {
                        console.error('Error:', error);
                    });
                }
            });
        }
    }
});
</script>
