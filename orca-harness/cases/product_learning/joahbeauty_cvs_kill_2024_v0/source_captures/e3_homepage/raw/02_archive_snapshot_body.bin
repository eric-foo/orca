<!--Joah Mobile Menu with  special sticky script  -->
<style>


* {
	box-sizing: border-box;
}


a {
	text-decoration: none;
}

body::after {
    content: '';
    position: fixed;
    z-index: 9999999;
    height: 100vh;
    width: 100vw;
    transition: 0.4s;
    opacity: 0;
    visibility: hidden;
    top: 0;
    left: -360px;
    background-color: hsla(0,0%,7%,.36);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
}

.nav-is-toggled {
    opacity: 1;
    visibility: visible;
    transition: opacity .8s ease,visibility 0s;

}

.pre-scrim {
    background-color: hsla(0,0%,7%,.36);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
}






.nav-top {
    display: flex;
    align-items: center;
    /* position: fixed; */
    z-index: 999999999;
    padding: 10px 20px;
    /* width: 100%; */
    height: 50px;
    background-color: #fff;
    order: 10;
}


.nav-top .hamburger {
    margin-left: auto;
    color: #000;
    cursor: pointer;
    font-size: 33px;
}



.hamburger::after{
    content: "menu";
    margin-right: 0.1em;
    font-family: 'Material Symbols Outlined';
    font-size: 3.7rem;
    color: #000;

}

.nav-is-toggled .hamburger::after {
    content: "close";
    margin-right: 0.1em;
    font-family: 'Material Symbols Outlined';
    font-size: 3.7rem;
    color: #000;
}

