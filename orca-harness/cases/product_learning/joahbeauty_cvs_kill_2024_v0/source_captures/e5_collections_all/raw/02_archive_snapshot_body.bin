:root {
    --color-typography-primary: #4c4a3f;
    --color-typography-body: #4c4a3f;
    --color-typography-secondary: #dddcd9;
    --color-typography-accent: #ffffff;

    --color-background-body: #ffffff;
    --color-background-elements: #ffffff;
    --color-background-bg-1: #f6f6f5;
    --color-background-bg-2: #4c4a3f;
    --color-background-images: #f6f6f5;

    --color-border-1: #eeeeec;
    --color-border-2: #eeeeec;

    --color-buttons-primary: #080808;

    --color-hover-buttons-primary: #4c4a3f;
    --color-hover-buttons-primary-text: #ffffff;

    --color-buttons-primary-text: #ffffff;
    --color-buttons-secondary: #dddddd;
    --color-buttons-secondary-text: #4c4a3f;

    --color-buttons-secondary-hover: #1b1a1f;
    --color-buttons-secondary-hover-text: #dddddd;

    --color-buttons-tertiary: #363f4d;
    --color-buttons-tertiary-text: #ffffff;

    --color-buttons-tertiary-hover: #1b1a1f;
    --color-buttons-tertiary-hover-text: #ffffff;

    --buttons-border-width: 0;

    --color-badge: #ffffff;
    --color-badge-text: #4c4a3f;

    --color-sale-tag: #ffffff;
    --color-sale-tag-text: #666666;

    --color-discounted-price: #808080;
    --color-sale-price: #f26363;

    --color-header-bar: #F6f6f6;
    --color-header-bar-text: #4c4a3f;
    --color-header: #ffffff;
    --color-header-text: #4c4a3f;
    --color-header-text-transparent: #4c4a3f;
    --color-header-accent: #4c4a3f;
    --color-header-accent-text: #ffffff;

    --color-footer: #40393b;
    --color-footer-text: #ffffff;
    --color-footer-text-secondary: #808080;

    --font-heading-family: Poppins, sans-serif;
    --font-heading-style: normal;
    --font-heading-weight: 400;

    --font-heading1-size: 64px;
    --font-heading2-size: 48px;
    --font-heading3-size: 40px;
    --font-heading4-size: 32px;
    --font-heading5-size: 24px;
    --font-heading6-size: 20px;

    --font-heading1-mobile-size: 40px;
    --font-heading2-mobile-size: 32px;
    --font-heading3-mobile-size: 24px;
    --font-heading4-mobile-size: 20px;
    --font-heading5-mobile-size: 16px;
    --font-heading6-mobile-size: 12px;


    --font-buttons-family: Poppins, sans-serif;
    --font-buttons-style: normal;
    --font-buttons-weight: 500;
    --buttons-letter-spacing: 0.1rem;
    --buttons-text-transform: uppercase;
    --font-buttons-size: 16px;

    --font-body-family: Poppins, sans-serif;
    --font-body-style: normal;
    --font-body-weight: 400;

    --font-body-scale: 1.0;
    --font-heading-scale: 1.0;

    --navigation-font-weight: 400;

    --font-size-product-card: 1.4rem;

    --vendor-font-size-product-card: 1.4rem;

    --color-red: #e22828;
  }.motion-reduce,
    .motion-reduce::before,
    .motion-reduce::after,
    .motion-reduce > svg,
    .button,
    .button::before,
    #shopify-product-reviews .spr-button::before,
    .shopify-payment-button__button--unbranded::before {
      transition: none !important;
      animation: none !important;
    }</style>

<noscript>
  <style data-shopify>
    [data-fade-in] {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>
