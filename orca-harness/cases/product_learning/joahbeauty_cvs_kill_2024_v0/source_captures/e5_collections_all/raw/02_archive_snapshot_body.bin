            },
            'checkoutEmail' : null,
            'currency'      : "USD",
            'pageType'      : 'Log State',
            'event'         : 'Log State'
        }
        
        dataLayer.push(logState);
        if(__DL__.debug){
            console.log("Log State"+" :"+JSON.stringify(logState, null, " "));
        }
        
        /** 
        * DATALAYER: Homepage */
        
        if(document.location.pathname == "/"){
            var homepage = {
                'pageType' : 'Homepage',
                'event'    : 'Homepage'
            };
            dataLayer.push(homepage);
            if(__DL__.debug){
                console.log("Homepage"+" :"+JSON.stringify(homepage, null, " "));
            }
        }
        
