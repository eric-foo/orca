document.addEventListener('DOMContentLoaded', function() {
  var variantRadios = document.querySelectorAll('.product-form input[type="radio"]');
  var variantMessage = document.querySelector('.variant-message');
  
  // check if 50ml input is selected on page load
  var selectedVariant = document.querySelector('.product-form input[type="radio"]:checked');
  if (selectedVariant.value.indexOf('50ml') !== -1) {
    variantMessage.style.display = 'block';
  } else {
    variantMessage.style.display = 'none';
  }
  
  // add click event listener to variant radio buttons
  for (var i = 0; i < variantRadios.length; i++) {
    variantRadios[i].addEventListener('click', function() {
      var selectedVariantValue = this.value;
      if (selectedVariantValue.indexOf('50ml') !== -1) {
        variantMessage.style.display = 'block';
      } else {
        variantMessage.style.display = 'none';
      }
    });
  }
});
