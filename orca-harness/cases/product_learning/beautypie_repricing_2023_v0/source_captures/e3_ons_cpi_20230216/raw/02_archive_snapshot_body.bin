<div class="scrollable-container">
<div id="chart-f487e7d7" data-filename="f487e7d7" data-uri="/web/20230216220653oe_/https://www.ons.gov.uk/economy/inflationandpriceindices/bulletins/consumerpriceinflation/january2023/f487e7d7" class="markdown-chart">
<!--[if gt IE 8]><!--><noscript><!--[endif]-->
            <img src="/web/20230216220653im_/https://www.ons.gov.uk/chartimage?uri=/economy/inflationandpriceindices/bulletins/consumerpriceinflation/january2023/f487e7d7&amp;width=&amp;hideSource=true" alt=""/>
            <!--[if gt IE 8]><!--></noscript><!--[endif]-->
</div>
