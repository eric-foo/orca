<div class="product-grid-item js-product-wrapper js-grid-product " data-title="Dew Blush™" data-price="25.00" data-variant="44371256115376" data-product-handle="dew-blush">

  
  <script type="application/json" class="js-product-data" data-id="6535822311600" data-handle="dew-blush">
    {"id":6535822311600,"title":"Dew Blush™","handle":"dew-blush","description":"\u003cp\u003e\u003c!-- x-tinymce\/html --\u003e\u003c\/p\u003e\n\u003cp class=\"sh-color-black sh-color\" dir=\"ltr\"\u003e\u003cspan class=\"sh-color-black sh-color\"\u003eDew Blush™ is sure to be your holy-grail essential for an effortless flush. With its blendable, liquid-cream formula and chunky doe-foot applicator, Dew Blush™ melts seamlessly into cheeks for a dewy wash of color. This lightweight, skin-loving formula lets you create a natural tint or build for a deeper wash of color that's never streaky or patchy. Now available in 11 shades for a wide range of complexions to find their perfect flush. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003eDew Blush™  is safe for \u003cstrong\u003esensitive skin, fragrance free, cruelty free, formulated without gluten and vegan. \u003c\/strong\u003e\u003c\/p\u003e","published_at":"2021-03-23T06:53:28-04:00","created_at":"2021-02-24T06:45:00-05:00","vendor":"Saie","type":"Finished Good","tags":["anti-aging","award-winning","badge:new","cheek","dimethicone-free","dry-skin","dullness","elderberry","essential oil-free","face","formulated-without-gluten","fragrance-free","gifts","glamour","hyperpigmentation","multi-use","new","Subscription","subscriptions","synthetic-dye-free","tyb","vegan"],"price":2500,"price_min":2500,"price_max":2500,"available":true,"price_varies":false,"compare_at_price":null,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":44371256115376,"title":"Flirty","option1":"Flirty","option2":null,"option3":null,"sku":"SBLU110INT","requires_shipping":true,"taxable":true,"featured_image":{"id":36420119068848,"product_id":6535822311600,"position":13,"created_at":"2025-04-22T12:09:39-04:00","updated_at":"2025-05-01T09:33:59-04:00","alt":"flirty","width":1080,"height":1080,"src":"\/\/web.archive.org\/web\/20250523193147\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle3_1a89124d-b9