g\/web\/20250523193147\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/c822ee7808cd448e89b5f68d1c24dc1e\/c822ee7808cd448e89b5f68d1c24dc1e.m3u8?v=0","width":606}]}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"29f14af005b6a36aab0617f0ee0e9027aaa08c7e","name":"Subscribe \u0026 Save","options":[{"name":"Deliver every","position":1,"values":["1 month","2 month","3 months","4 months"]}],"selling_plans":[{"id":2368831664,"name":"Every 1 month","description":null,"options":[{"name":"Deliver every","position":1,"value":"1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368864432,"name":"Every 2 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"2 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368897200,"name":"Every 3 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368929968,"name":"Every 4 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"5859381"}],"content":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eSuper luxurious and super plush, SuperSuede™ Baked Powder Blush is the new standard for baked powder blush. Hand-whipped and baked using time-honored Italian techniques, SuperSuede™ has a velvety texture that melts into skin for an impossibly lightweight, diffused \u003c\/span\u003e\u003cspan\u003eflush of color\u003c\/span\u003e\u003cspan\u003e with a natural-blurred finish. With a curated palette of six shades, SuperSuede™ Blush gives effortless, breathable color payoff, and works for a wide range of looks. SuperSuede™ is also non-comedogenic, long-wearing, and never patchy, cakey, or drying.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003ePair with NEW: \u003ca href=\"https:\/\/www.saiehello.com\/products\/the-powder-blush-brush\"\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eThe Powder Blush Brush\u003c\/strong\u003e\u003c\/span\u003e\u003c\/a\u003e, intentionally designed for SuperSuede™ for precise, seamless application.  \u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eWe recommend keeping SuperSuede™ out of direct lighting, both natural and artificial, when not in use. Since this formula contains some light-sensitive pigments, excess light may affect the top layer. Simply dust off the top layer to return to normal.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e \u003c\/p\u003e"}
  </script>

