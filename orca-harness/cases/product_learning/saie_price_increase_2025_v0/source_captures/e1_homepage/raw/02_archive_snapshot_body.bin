document.querySelectorAll('.js-slider-products-new').forEach(function (sliderEl) {
  new Swiper(sliderEl, {
    slidesPerView: 1.05,
    freeMode: false,
 mousewheel: {
          forceToAxis: true
        },
    breakpoints: {
      768: {
        slidesPerView: 3.1,
        freeMode: false,
      },
      1023: {
        slidesPerView: 4.1,
        freeMode: false,
      }
    }
  });
});

</script>


</div><section id="shopify-section-template--17584120496304__rs_image_side_by_w7ANVz" class="shopify-section rs-section-image-side-by"><style>
.grid-images .grid__image + .grid__image{margin-top:30px}.grid-images img{width:100%;height:100%;object-fit:cover}.grid-images .grid__image{position:relative}.grid-images .grid__image-stamp{position:absolute;top:-40px;right:-25px;width:80px;height:80px}.grid-images .grid__image--alt img{object-fit:contain}@media (min-width:768px){.grid-images{display:flex;align-items:flex-start;gap:40px}.grid-images .grid__image-stamp{width:120px;height:120px}.grid-images .grid__image + .grid__image{margin-top:0}}@media (min-width:1024px){.grid-images{gap:153px}.grid-images .grid__image-stamp{width:216px;height:209px}.grid-images .grid__image{flex:1}.grid-images .grid__image--medium{flex:0 0 50%}.grid-images .grid__image--alt{margin-right:-18px;margin-top:-10px!important}.grid-images--alt .grid__image--alt{margin-right:-22px;margin-top:27px!important;margin-left:-21px}}

#rs-isbs-template--17584120496304__rs_image_side_by_w7ANVz{
	background-color: #f2f2f2 !important;
}


</style>
<div id="rs-isbs-template--17584120496304__rs_image_side_by_w7ANVz" class="gutter-padding--horizontal ">
				  <div class="grid-images ">
          <figure class="grid__image  grid__image--medium"><img src="//web.archive.org/web/20250523193147im_/https://saiehello.com/cdn/shop/files/F_F-2up.1.png?v=1747673874" alt="Saie Image" width="1935" height="2349" loading="lazy"></figure>

          <figure class="grid__image grid__image--alt"><img src="//web.archive.org/web/20250523193147im_/https://saiehello.com/cdn/shop/files/F_F-2up.2.png?v=1747673891" alt="Saie Image" width="1284" height="1551" loading="lazy"></figure>
        </div>
			</div>


<style> #shopify-section-template--17584120496304__rs_image_side_by_w7ANVz .grid-images {align-items: center;} </style></section><div id="shopify-section-template--17584120496304__16451269836a3edf29" class="shopify-section">
<style>
  .featured-products.featured-products-new-slider {
  padding-block: 60px;    
}

.slider-products-new .slider__clip {
  padding-inline: 13px;
}


@media (min-width: 768px) {
 .featured-products-new-slider .gutter-padding--horizontal--mobile {
    margin-inline: 16px;
  }
}

@media (max-width: 1050px) {
  .featured-products.featured-products-new-slider {
    padding-block: 50px;    
  } 
}

@media (max-width: 750px) {
