m\/cdn\/shop\/videos\/c\/vp\/952170288c2c4bdcbf6f18dd82182565\/952170288c2c4bdcbf6f18dd82182565.m3u8?v=0","width":606}]},{"alt":"slideshow","id":26106892714160,"position":139,"preview_image":{"aspect_ratio":1.0,"height":2000,"width":2000,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0002_Jocelyne_Shade_1_384_1.jpg?v=1722871440"},"aspect_ratio":1.0,"height":2000,"media_type":"image","src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0002_Jocelyne_Shade_1_384_1.jpg?v=1722871440","width":2000},{"alt":"slideshow","id":26106892746928,"position":140,"preview_image":{"aspect_ratio":1.0,"height":2000,"width":2000,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0003_Bea_Shade_9_074.jpg?v=1722871440"},"aspect_ratio":1.0,"height":2000,"media_type":"image","src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0003_Bea_Shade_9_074.jpg?v=1722871440","width":2000},{"alt":"slideshow","id":26106892648624,"position":141,"preview_image":{"aspect_ratio":1.0,"height":2000,"width":2000,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0000_Isolde_Shade_16_355_1.jpg?v=1722871440"},"aspect_ratio":1.0,"height":2000,"media_type":"image","src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0000_Isolde_Shade_16_355_1.jpg?v=1722871440","width":2000},{"alt":"slideshow","id":26106892681392,"position":142,"preview_image":{"aspect_ratio":1.0,"height":2000,"width":2000,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0001_Samira_Shade_13_384.jpg?v=1722871440"},"aspect_ratio":1.0,"height":2000,"media_type":"image","src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0001_Samira_Shade_13_384.jpg?v=1722871440","width":2000},{"alt":"slideshow","id":26106892779696,"position":143,"preview_image":{"aspect_ratio":1.0,"height":2000,"width":2000,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0004_Amanda_B_Shade_5_0346.jpg?v=1722871440"},"aspect_ratio":1.0,"height":2000,"media_type":"image","src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0004_Amanda_B_Shade_5_0346.jpg?v=1722871440","width":2000},{"alt":"slideshow","id":26106892812464,"position":144,"preview_image":{"aspect_ratio":1.0,"height":2000,"width":2000,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0005_Alex_O_Shade_11_1004_1.jpg?v=1722871440"},"aspect_ratio":1.0,"height":2000,"media_type":"image","src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/concealercarousel_0005_Alex_O_Shade_11_1004_1.jpg?v=1722871440","width":2000}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"a512f6c324b2a37f8701ef638bed9aba2c7a8cd1","name":"Subscribe \u0026 Save 10%","options":[{"name":"Selling plan name","position":1,"values":["Every 1 month","Every 2 months","Every 3 months","Every 4 months"]}],"selling_plans":[{"id":2080047280,"name":"Every 1 month","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080080048,"name":"Every 2 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 2 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080112816,"name":"Every 3 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2082439344,"name":"Every 4 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"Yotpo Echo"}],"content":"\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eSaie hello to Slip Tint Radiant All-Over Concealer, your multi-tasking essential for instant skin confidence. Slip Tint Concealer has medium coverage that undetectably \u003cspan data-mce-fragment=\"1\"\u003econceals imperfections, from redness to dark circles, and wears for up to 12 hours.\u003c\/span\u003e Its lightweight, cream formula melts into skin for the freshest, most natural-radiant finish.  \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eWe’ve done the work so you can feel confident applying this effortless, non-comedogenic concealer, knowing it will care for your skin in the moment and over time. \u003cspan data-mce-fragment=\"1\"\u003eBased on a clinical and consumer perception study, Slip Tint Concealer has been proven to minimize pore size, smooth skin, and improve the appearance of blemishes and fine lines while never caking, creasing or looking greasy throughout the day.*\u003c\/span\u003e\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003ePowered by Saie Science, Slip Tint’s formula is supercharged with soothing Niacinamide, hydrating Hyaluronic Acid and plumping Plant-Derived Glycerin. Stack effortlessly with \u003c\/span\u003e\u003ca style=\"font-weight: 400;\" rel=\"noopener\" href=\"www.saiehello.com\/products\/slip-tint-tinted-moisturizer\" target=\"_blank\"\u003e\u003cstrong\u003eSlip Tint Tinted Moisturizer\u003c\/strong\u003e\u003c\/a\u003e\u003cspan\u003e and all of our essentials for The Signature SaieGlow™. Slip Tint Concealer is also dermatologist tested, sensitive-skin friendly, ophthalmologist tested** and vegan. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003e\u003cspan\u003e*Based on a clinical and consumer perception study.\u003c\/span\u003e\u003cu class=\"sh-color-black sh-color\"\u003e\u003cbr\u003e\u003c\/u\u003e\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003eIn a clinical and consumer perception study over 4 weeks, 32 women ages 39-69 agreed: \u003c\/p\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp\u003e100% of subjects had minimization of pore size at 2 and 4 weeks.*\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli\u003e\n\u003cp\u003e100% of subjects had improvement in the appearance of fine lines and crows feet at 2 and 4 weeks.*\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli\u003e\n\u003cp\u003e97%  agreed it did not settle or crease throughout the day, was crease resistant, and did not crack or cling to patches on skin after application and\/or throughout the day.**\u003c\/p\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003cp\u003e*Clinical Evaluation \u003c\/p\u003e\n\u003cp\u003e**Consumer Perception \u003c\/p\u003e\n\u003cp\u003eFormulated without Gluten, Vegan\u003c\/p\u003e\n\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003e\u003cu class=\"sh-color-black sh-color\"\u003e\u003cbr\u003e\u003c\/u\u003e\u003c\/span\u003e\u003c\/p\u003e"}
  </script>

