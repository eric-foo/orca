<div class="product-grid-item js-product-wrapper js-grid-product " data-title="Glossybounce™" data-price="22.00" data-variant="42779189149872" data-product-handle="glossybounce">

  
  <script type="application/json" class="js-product-data" data-id="7362040332464" data-handle="glossybounce">
    {"id":7362040332464,"title":"Glossybounce™","handle":"glossybounce","description":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eThe slip of a lip oil meets the high-shine of a tinted gloss. Glossybounce\u003c\/span\u003e\u003cspan\u003e™\u003c\/span\u003e\u003cspan\u003e is our best-selling, high-shine lip gloss-oil hybrid with a plush, cushiony feel that’s never sticky or tacky. This long-lasting, vegan lip essential is supercharged with nourishing, hydrating ingredients for soft lips and your juiciest shine ever! Available in nine shades: six sheer, my-lips-but-better shades and three elegant, ultra-fine shimmer shades. Get a Glossybounce\u003c\/span\u003e\u003cspan\u003e™\u003c\/span\u003e\u003cspan\u003e \u003c\/span\u003e\u003cspan\u003efor every bag! \u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eGlossybounce™ is formulated without natural or synthetic fragrance and with a touch of natural stevia for taste. You may notice the scent of raw ingredients but this fades quickly after application\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e","published_at":"2023-08-22T16:29:41-04:00","created_at":"2023-08-16T17:45:45-04:00","vendor":"Saie","type":"","tags":["cruelty-free","dullness","lip","lips","new","Shade Finder","Subscription","vegan","Verishop"],"price":2200,"price_min":2200,"price_max":2200,"available":true,"price_varies":false,"compare_at_price":null,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":42779189149872,"title":"Kiss","option1":"Kiss","option2":null,"option3":null,"sku":"01GLOSS05A","requires_shipping":true,"taxable":true,"featured_image":{"id":33244363718832,"product_id":7362040332464,"position":5,"created_at":"2023-08-16T18:53:57-04:00","updated_at":"2023-08-16T18:53:57-04:00","alt":"kiss","width":1080,"height":1080,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/products\/silos-_0002_01_Glossybounce_Silos_Kiss_00