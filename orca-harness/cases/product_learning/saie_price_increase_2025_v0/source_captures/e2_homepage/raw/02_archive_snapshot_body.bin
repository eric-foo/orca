heckout_charge":{"value_type":"percentage","value":100}},{"id":2080112816,"name":"Every 3 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2082439344,"name":"Every 4 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"Yotpo Echo"}],"content":"\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003e85% skincare serum, 15% weightless pigment for 100% your best skin ever. Our lightweight skin tint foundation provides skincare benefits, medium coverage and a luminous, second-skin finish. Press in this lightweight serum formula like you would your skincare serum to get all the benefits of Glowy Super Skin’s supercharged ingredients like Hyaluronic Acid and Rice Bran Peptides for visibly plumper, more hydrated, and brighter skin. So weightless and breathable that you’ll forget you’re wearing foundation at all. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cb\u003e85% SUPERCHARGED INGREDIENTS: \u003cbr\u003e\u003c\/b\u003e\u003cb style=\"font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; font-size: 0.875rem;\"\u003eHyaluronic Acid  - \u003c\/b\u003e\u003cspan style=\"font-weight: 400;\"\u003eAttracts and binds moisture to smooth and hydrate skin\u003cbr\u003e\u003cbr\u003e\u003c\/span\u003e\u003cb style=\"font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; font-size: 0.875rem;\"\u003eRice Bran Peptides - \u003c\/b\u003e\u003cspan style=\"font-weight: 400;\"\u003eReduces the appearance of fine lines, pore, helps fade dark spots brightening skin tone.\u003cbr\u003e\u003cbr\u003e\u003c\/span\u003e\u003cb style=\"font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; font-size: 0.875rem;\"\u003ePolyglutamic Acid -\u003c\/b\u003e\u003cspan style=\"font-weight: 400;\"\u003e Hydrates the skin while locking in moisture to soften the appearance of fine lines, pores and plump the skin.\u003cbr\u003e\u003cbr\u003e\u003c\/span\u003e\u003cb style=\"font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; font-size: 0.875rem;\"\u003eGlycerin - \u003c\/b\u003e\u003cspan style=\"font-weight: 400;\"\u003eA powerful humectant known to increase skin’s natural moisture level.\u003c\/span\u003e\u003c\/p\u003e"}
  </script>

