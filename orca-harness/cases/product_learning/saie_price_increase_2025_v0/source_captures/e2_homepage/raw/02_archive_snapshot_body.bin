<div class="product-grid-item js-product-wrapper js-grid-product " data-title="Saie" s candy box' data-price="240.00" data-variant="43952444768432" data-product-handle="saies-candy-box">

  
  <script type="application/json" class="js-product-data" data-id="7729665605808" data-handle="saies-candy-box">
    {"id":7729665605808,"title":"Saie's Candy Box","handle":"saies-candy-box","description":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eWe set aside an\u003c\/span\u003e\u003cspan\u003e \u003c\/span\u003e\u003cspan\u003eextremely limited quantity of the much-loved PR box for our super fans. Saie’s Candy Box is the ultimate sweet treat with all five shades of Lip Liner 101™ and all nine shades of Glossybounce™ Lip Gloss Oils in limited edition packaging. Buy yours before it’s gone forever! \u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eSaie’s Candy Box Features: \u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003e\u003cstrong\u003eGlossybounce™ - High-Shine Hydrating Lip Gloss OIl\u003c\/strong\u003e \u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eKiss – Clear\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eDip – Dusty Rose\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003ePlay – Bright Pink\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eBounce – Mauve \u003cbr\u003e\u003c\/span\u003e\u003cspan\u003ePush – Soft Brown\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eDream – Berry\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eNEW! Disco - Pinky rose \u003c\/span\u003e\u003cspan\u003eshimmer\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eNEW! Shake - Warm nude \u003c\/span\u003e\u003cspan\u003eshimmer\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eNEW! Remix - Mauve \u003c\/span\u003e\u003cspan\u003eshimmer\u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cstrong\u003e\u003cbr\u003eLip Liner 101™ – Creamy \u0026amp; Defining Lip Pencil \u003c\/strong\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eFRENCH - \u003c\/span\u003e\u003cspan\u003epink nude\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eWINK - \u003c\/span\u003e\u003cspan\u003erose nude\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eFLIRT - \u003c\/span\u003e\u003cspan\u003ecaramel nude\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eTWIST - \u003c\/span\u003e\u003cspan\u003emauve nude\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eTEASE- plum brown nude\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e","published_at":"2024-10-11T08:33:07-04:00","created_at":"2024-10-11T07:53:19-04:00","vendor":"Saie","type":"Finished Good","tags":["new"],"price":24000,"price_min":24000,"price_max":24000,"available":true,"price_varies":false,"compare_at_price":0,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":43952444768432,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"GBLLMAILER2","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"name":"Saie's Candy Box","public_title":null,"options":["Default Title"],"price":24000,"weight":0,"compare_at_price":0,"inventory_management":"shopify","barcode":null,"requires_selling_plan":false,"selling_plan_allocations":[],"quantity_rule":{"min":1,"max":null,"increment":1}}],"images":["\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/saiecandybox_insidelid_3c63c417-4c70-40f0-ae08-6b2407867eda.png?v=1731686105","\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/saiecandybox_open_7843db6a-a5d8-41ae-ba90-a2aa3d3133b5.png?v=1731686105"],"featured_image":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/saiecandybox_insidelid_3c63c417-4c70-40f0-ae08-6b2407867eda.png?v=1731686105","options":["Title"],"media":[{"alt":null,"id":27645986865328,"position":1,"preview_image":{"aspect_ratio":1.0,"height":1000,"width":1000,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/files\/saiecandybox_insidelid_3c63c417-4c70-40f0-ae08-6b2407867eda.png?v=1731686105"},"aspect_ratio":1.0,"height":1000,"media_type":"image","src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/fil