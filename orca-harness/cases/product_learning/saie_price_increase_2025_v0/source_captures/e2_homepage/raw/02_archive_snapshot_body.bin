\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/9b813d660590487c9026156e1285354e\/9b813d660590487c9026156e1285354e.SD-480p-1.5Mbps-35677484.mp4?v=0","width":270},{"format":"mp4","height":1080,"mime_type":"video\/mp4","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/9b813d660590487c9026156e1285354e\/9b813d660590487c9026156e1285354e.HD-1080p-7.2Mbps-35677484.mp4?v=0","width":606},{"format":"mp4","height":720,"mime_type":"video\/mp4","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/9b813d660590487c9026156e1285354e\/9b813d660590487c9026156e1285354e.HD-720p-4.5Mbps-35677484.mp4?v=0","width":404},{"format":"m3u8","height":1080,"mime_type":"application\/x-mpegURL","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/9b813d660590487c9026156e1285354e\/9b813d660590487c9026156e1285354e.m3u8?v=0","width":606}]}],"requires_selling_plan":false,"selling_plan_groups":[],"content":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eFor the gloss-lover in your life. This limited edition wreath includes the full collection of our bestselling, high-shine Glossybounce™ lip gloss-oils for juicy, kissable lips. All nine, sheer and shimmer, shades pre-wrapped and ready to gift in sustainable paper packaging. Extremely limited quantities. Grab and gift yours before it sells out! \u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eAll holiday sets are pre-wrapped in sustainable, 100% FSC-certified limited edition holiday paper packaging– perfect for grabbing and gifting! Simply recycle at home once unwrapped.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cstrong\u003eSHADE DESCRIPTIONS:\u003c\/strong\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cul\u003e\n\u003cli dir=\"ltr\" aria-level=\"1\"\u003e\n\u003cp dir=\"ltr\" role=\"presentation\"\u003e\u003cspan\u003eFull-Size Glossybounce™ in Kiss – Clear\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\" aria-level=\"1\"\u003e\n\u003cp dir=\"ltr\" role=\"presentation\"\u003e\u003cspan\u003eFull-Size Glossybounce™ in Dip – Dusty Rose\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\" aria-level=\"1\"\u003e\n\u003cp dir=\"ltr\" role=\"presentation\"\u003e\u003cspan\u003eFull-Size Glossybounce™ in Play – Bright Pink\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\" aria-level=\"1\"\u003e\n\u003cp dir=\"ltr\" role=\"presentation\"\u003e\u003cspan\u003eFull-Size Glossybounce™ in Bounce – Mauve \u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\" aria-level=\"1\"\u003e\n\u003cp dir=\"ltr\" role=\"presentation\"\u003e\u003cspan\u003eFull-Size Glossybounce™ in Push – Soft Brown\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\" aria-level=\"1\"\u003e\n\u003cp dir=\"ltr\" role=\"presentation\"\u003e\u003cspan\u003eFull-Size Glossybounce™ in Dream – Berry\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\" aria-level=\"1\"\u003e\n\u003cp dir=\"ltr\" role=\"presentation\"\u003e\u003cspan\u003eFull-Size Glossybounce™ in \u003c\/span\u003e\u003cspan\u003eDisco - \u003c\/span\u003e\u003cspan\u003ePinky rose shimmer\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\" aria-level=\"1\"\u003e\n\u003cp dir=\"ltr\" role=\"presentation\"\u003e\u003cspan\u003eFull-Size Glossybounce™ in \u003c\/span\u003e\u003cspan\u003eShake - \u003c\/span\u003e\u003cspan\u003eWarm nude shimmer\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\" aria-level=\"1\"\u003e\n\u003cp dir=\"ltr\" role=\"presentation\"\u003e\u003cspan\u003e\u003c\/span\u003eFull-Size Glossybounce™ in Remix - Mauve shimmer\u003c\/p\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e"}
  </script>

