mat":"mp4","height":1080,"mime_type":"video\/mp4","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/fa21d8200ac04723b93c81e8c0711504\/fa21d8200ac04723b93c81e8c0711504.HD-1080p-7.2Mbps-34148651.mp4?v=0","width":1080},{"format":"mp4","height":720,"mime_type":"video\/mp4","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/fa21d8200ac04723b93c81e8c0711504\/fa21d8200ac04723b93c81e8c0711504.HD-720p-4.5Mbps-34148651.mp4?v=0","width":720},{"format":"m3u8","height":1080,"mime_type":"application\/x-mpegURL","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/fa21d8200ac04723b93c81e8c0711504\/fa21d8200ac04723b93c81e8c0711504.m3u8?v=0","width":1080}]}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"a512f6c324b2a37f8701ef638bed9aba2c7a8cd1","name":"Subscribe \u0026 Save 10%","options":[{"name":"Selling plan name","position":1,"values":["Every 1 month","Every 2 months","Every 3 months","Every 4 months"]}],"selling_plans":[{"id":2080047280,"name":"Every 1 month","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080080048,"name":"Every 2 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 2 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080112816,"name":"Every 3 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2082439344,"name":"Every 4 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"Yotpo Echo"}],"content":"\u003cp class=\"p1\"\u003eRethink everything you know about lip liner. Saie hello to Lip Liner 101™, the most foolproof, confusion free, and nourishing lip liner that makes it effortless to enhance your natural lip shape. The luxuriously creamy, soft matte formula glides on smoothly for a naturally framed or fully filled look with no tugging, tightness, feathering, or dryness—all in an elegantly understated, classic wooden pencil that minimizes excess packaging. Lip Liner 101™ comes in five versatile neutral shades that stack perfectly with your favorite gloss – like Glossybounce™ – for a timeless lip combo.\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003ePowered by Saie Science, Lip Liner 101’s formula is supercharged with Shea Butter, Jojoba Oil and Meadowfoam Oil for a comfortable, nourishing essential. Lip Liner 101 is vegan, cruelty free and safe for sensitive skin.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e"}
