<div class="product-grid-item js-product-wrapper js-grid-product " data-title="Sun Melt" data-price="32.00" data-variant="42495670321328" data-product-handle="sun-melt">

  
  <script type="application/json" class="js-product-data" data-id="6702661730480" data-handle="sun-melt">
    {"id":6702661730480,"title":"Sun Melt","handle":"sun-melt","description":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eA cream-balm bronzer with a natural-radiant finish that melts in for an effortless all-over bronze. Paired with \u003ca href=\"www.saiehello.com\/products\/the-big-brush\" target=\"_blank\" rel=\"noopener\"\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eThe Big Brush\u003c\/strong\u003e\u003c\/span\u003e\u003c\/a\u003e, Sun Melt’s creamy texture makes it easy to build and blend your look without overdoing it. Powered by Saie Science, Sun Melt’s formula is supercharged with ingredients like Colloidal Oatmeal to soothe and smooth, nourishing Grapeseed Oil and free-radical fighting Elderberry Extract. Available in six seamless shades of sun-kissed color.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e","published_at":"2021-06-14T13:06:13-04:00","created_at":"2021-06-02T18:25:52-04:00","vendor":"Saie","type":"","tags":["allure-2022","allure-2024","award-winning","cheek","colloidal-oatmeal","dimethicone-free","dry-skin","dullness","elderberry","essential oil-free","face","formulated-without-gluten","jojoba-esters","multi-use","oily-skin","Shade Finder","soy-free","Subscription","subscriptions","synthetic-dye-free","Verishop"],"price":3200,"price_min":3200,"price_max":3200,"available":true,"price_varies":false,"compare_at_price":null,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":42495670321328,"title":"Fair Bronze","option1":"Fair Bronze","option2":null,"option3":null,"sku":"MELT050GBL","requires_shipping":true,"taxable":true,"featured_image":{"id":32973486424240,"product_id":6702661730480,"position":3,"created_at":"2023-03-15T18:10:45-04:00","updated_at":"2023-08-22T16:58:45-04:00","alt":"fair bronze primary","width":1080,"height":1080,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/products\/fair-bronze-small_2aa191e1-