<div class="product-grid-item js-product-wrapper js-grid-product " data-title="Mini Glowy Super Gel Duo" data-price="24.00" data-variant="43863424008368" data-product-handle="glowy-super-gel-duo-2024">

  
  <script type="application/json" class="js-product-data" data-id="7706741866672" data-handle="glowy-super-gel-duo-2024">
    {"id":7706741866672,"title":"Mini Glowy Super Gel Duo","handle":"glowy-super-gel-duo-2024","description":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eYour favorite stocking stuffer is back! This holiday duo features two mini sizes of Glowy Super Gel, the cult favorite multipurpose illuminator. This set includes bestselling universal bronze gold shade, Sunglow, and – back by extremely popular demand– the limited edition universal soft warm golden shade, Warmglow. Perfect for instantly creating illuminated looks and fresh, dewy skin this holiday season.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eAll holiday sets are pre-wrapped in sustainable, 100% FSC-certified limited edition holiday paper packaging– perfect for grabbing and gifting! Simply recycle at home once unwrapped.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003e\u003cstrong\u003eSunglow\u003c\/strong\u003e\u003c\/span\u003e\u003ci\u003e\u003cspan style=\"font-weight: 400;\"\u003e - \u003c\/span\u003e\u003c\/i\u003e\u003cspan style=\"font-weight: 400;\"\u003e(bronze gold) for a back-from-vacation glow\u003cbr\u003e\u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003e\u003cstrong\u003eWarmglow\u003c\/strong\u003e - (soft warm gold) for a candlelit glow\u003c\/span\u003e\u003c\/p\u003e","published_at":"2024-10-05T00:00:05-04:00","created_at":"2024-08-21T11:30:16-04:00","vendor":"Saie","type":"Finished Good","tags":["gifts","holiday"],"price":2400,"price_min":2400,"price_max":2400,"available":true,"price_varies":false,"compare_at_price":0,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":43863424008368,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"SHOL2024","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"name":"Mini Glowy Super Gel Duo","public_title":null,"options":["Default Title"],"price":2400,"weight":0,