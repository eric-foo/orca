es":["Every 1 month","Every 2 months","Every 3 months","Every 4 months"]}],"selling_plans":[{"id":2080047280,"name":"Every 1 month","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080080048,"name":"Every 2 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 2 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080112816,"name":"Every 3 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2082439344,"name":"Every 4 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"Yotpo Echo"}],"content":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eThe slip of a lip oil meets the high-shine of a tinted gloss. Glossybounce\u003c\/span\u003e\u003cspan\u003e™\u003c\/span\u003e\u003cspan\u003e is our best-selling, high-shine lip gloss-oil hybrid with a plush, cushiony feel that’s never sticky or tacky. This long-lasting, vegan lip essential is supercharged with nourishing, hydrating ingredients for soft lips and your juiciest shine ever! Available in nine shades: six sheer, my-lips-but-better shades and three elegant, ultra-fine shimmer shades. Get a Glossybounce\u003c\/span\u003e\u003cspan\u003e™\u003c\/span\u003e\u003cspan\u003e \u003c\/span\u003e\u003cspan\u003efor every bag! \u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eGlossybounce™ is formulated without natural or synthetic fragrance and with a touch of natural stevia for taste. You may notice the scent of raw ingredients but this fades quickly after application\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e"}
  </script>

