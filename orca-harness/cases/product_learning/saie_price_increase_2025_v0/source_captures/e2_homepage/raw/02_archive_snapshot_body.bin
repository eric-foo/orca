vp\/33ff18b4b53e458fb14330d9beadd1f4\/33ff18b4b53e458fb14330d9beadd1f4.m3u8?v=0","width":608}]},{"alt":"carousel video","id":22148252827824,"position":39,"preview_image":{"aspect_ratio":0.563,"height":640,"width":360,"src":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/products\/7a20f8a5729544e9a298507ca8f676b3.thumbnail.0000000.jpg?v=1631661180"},"aspect_ratio":0.563,"duration":25025,"media_type":"video","sources":[{"format":"mp4","height":480,"mime_type":"video\/mp4","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/7a20f8a5729544e9a298507ca8f676b3\/7a20f8a5729544e9a298507ca8f676b3.SD-480p-0.9Mbps.mp4?v=0","width":270},{"format":"m3u8","height":480,"mime_type":"application\/x-mpegURL","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/7a20f8a5729544e9a298507ca8f676b3\/7a20f8a5729544e9a298507ca8f676b3.m3u8?v=0","width":270}]}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"a512f6c324b2a37f8701ef638bed9aba2c7a8cd1","name":"Subscribe \u0026 Save 10%","options":[{"name":"Selling plan name","position":1,"values":["Every 1 month","Every 2 months","Every 3 months","Every 4 months"]}],"selling_plans":[{"id":2080047280,"name":"Every 1 month","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080080048,"name":"Every 2 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 2 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080112816,"name":"Every 3 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2082439344,"name":"Every 4 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"Yotpo Echo"}],"content":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eA cream-balm bronzer with a natural-radiant finish that melts in for an effortless all-over bronze. Paired with \u003ca href=\"www.saiehello.com\/products\/the-big-brush\" target=\"_blank\" rel=\"noopener\"\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eThe Big Brush\u003c\/strong\u003e\u003c\/span\u003e\u003c\/a\u003e, Sun Melt’s creamy texture makes it easy to build and blend your look without overdoing it. Powered by Saie Science, Sun Melt’s formula is supercharged with ingredients like Colloidal Oatmeal to soothe and smooth, nourishing Grapeseed Oil and free-radical fighting Elderberry Extract. Available in six seamless shades of sun-kissed color.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e"}
