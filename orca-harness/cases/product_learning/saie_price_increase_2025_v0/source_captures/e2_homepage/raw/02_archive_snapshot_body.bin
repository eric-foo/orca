ype":"video\/mp4","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/d6b69f36ebae4f02b7d10dc7c03f18ac\/d6b69f36ebae4f02b7d10dc7c03f18ac.HD-720p-4.5Mbps-30898798.mp4?v=0","width":404},{"format":"m3u8","height":1080,"mime_type":"application\/x-mpegURL","url":"\/\/web.archive.org\/web\/20241126044550\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/d6b69f36ebae4f02b7d10dc7c03f18ac\/d6b69f36ebae4f02b7d10dc7c03f18ac.m3u8?v=0","width":606}]}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"a512f6c324b2a37f8701ef638bed9aba2c7a8cd1","name":"Subscribe \u0026 Save 10%","options":[{"name":"Selling plan name","position":1,"values":["Every 1 month","Every 2 months","Every 3 months","Every 4 months"]}],"selling_plans":[{"id":2080047280,"name":"Every 1 month","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080080048,"name":"Every 2 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 2 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2080112816,"name":"Every 3 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2082439344,"name":"Every 4 months","description":null,"options":[{"name":"Selling plan name","position":1,"value":"Every 4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"Yotpo Echo"}],"content":"\u003cp\u003e\u003cmeta charset=\"utf-8\"\u003e\u003cspan\u003eThe one and only glow — Saie hello to Glowy Super Gel, a lightweight multipurpose illuminator with a refreshing gel formula that gives an effortless radiance without glitter or strobe. There are no limits with how to use this iconic glow in a bottle: wear it alone, with makeup, mixed into skincare or wherever you want skin that glows from within.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan aria-label=\"\" class=\"c-mrkdwn__br\" data-stringify-type=\"paragraph-break\"\u003e\u003c\/span\u003e\u003cspan\u003ePowered by Saie Science, this non-comedogenic gel formula is supercharged with ultra-fine Micropearl, skin-quenching plant-derived Squalane, and moisturizing Glycerin. Glowy Super Gel is now available in three universal shades: Starglow (universal champagne glow), Sunglow (universal bronze gold glow), and NEW! Roseglow (universal rose gold glow).\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan aria-label=\"\" class=\"c-mrkdwn__br\" data-stringify-type=\"paragraph-break\"\u003e\u003c\/span\u003e\u003cspan\u003eCruelty-Free, Gluten-Free, Non-Comedogenic and Vegan\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan aria-label=\"\" class=\"c-mrkdwn__br\" data-stringify-type=\"paragraph-break\"\u003e\u003c\/span\u003e\u003cspan\u003eBest of 2022 Beauty - The Quality Edit\u003c\/span\u003e\u003cbr\u003e\u003cspan\u003eBest Clean Highlighter - Editorialist’s 2021 Triple Threat Beauty Awards\u003c\/span\u003e\u003c\/p\u003e"}
  </script>

