<div class="product-bis-form">
  <div class="position--relative">
    <div class="title-block spacing-small">
      
        
          <div>
            <h3 class="h3 italic">Notify me when back in stock</h3>
          </div>
        
      

      
        <div class="shopify-generated-content text-medium-small-body">
          <p>Sign up below to get first dibs when this product is back in stock.</p>
        </div>
      
    </div>

    <div class="js-lead-form">
      <form class="product-bis-form--form" data-public-key="Ka3QzC" data-type="back_in_stock">
        <input type="hidden" name="g" value="PM5bTE">
        <input type="hidden" name="variant" value="41038508523696" class="js-back-in-stock-variant">
        <input type="hidden" name="$fields" value="$source, email, $phone_number, $consent, sms_consent, Accepts Marketing, variant">
        <input type="hidden" name="$source" value="PDP - Airset">
        <input type="hidden" name="Accepts Marketing" value="true">
        <input type="hidden" name="sms_consent" value="true">

        

        <div class="js-lead-form-message" style="display:none;">
          <div class="h5">
            <p><p>Thank you! We’ll notify you when this product is back in stock.</p></p>
          </div>
        </div>

        <div class="js-lead-form-inputs">
          <div class="input-group">
            <input type="email" name="email" id="back_in_stock_form-email" class="input" value="" placeholder="Email" aria-label="Email" autocorrect="off" autocapitalize="off" autocomplete="off">
            </div>

            <div class="input-group">
              <input type="tel" name="$phone_number" id="signup-phone" placeholder="Phone" autocorrect="off" autocapitalize="off" class="input" maxlength="10" pattern="[0-9]{10}" oninvalid="this.setCustomValidity('Please enter a valid phone number.')" oninput="this.setCustomValidity(''); this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');">
            </div>

          <div class="input-group">
            <button type="submit" name="commit" id="Subscribe" class="btn--dark full-width" aria-label="Sign Up">
              <span>Notify Me</span>
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

