}

.productGiftIcon {
  	position: absolute !important;
    top: 10px !important;
    right: 10px !important;
    width: 15% !important;
    z-index: 1 !important;
    height: 15% !important;
    left: auto !important;
}
.svgTextValue {
  	display: inline-block;
    position: absolute;
    top: 50%;
    -webkit-transform: translateY(-50%);
    transform: translateY(-50%);
    left: 0;
    right: 0;
    margin: auto;
    text-align: center;
  	color: black;
}


