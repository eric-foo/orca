ype":"image","src":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/files\/eb9640f7-1431-4d2d-9292-e98c34575d8f.webp?v=1741638409","width":1500},{"alt":null,"id":28058605945008,"position":107,"preview_image":{"aspect_ratio":1.0,"height":1500,"width":1500,"src":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/files\/af0c41ff-2287-469c-b58f-e4f0507bed8d.webp?v=1741638417"},"aspect_ratio":1.0,"height":1500,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/files\/af0c41ff-2287-469c-b58f-e4f0507bed8d.webp?v=1741638417","width":1500},{"alt":null,"id":28058607124656,"position":108,"preview_image":{"aspect_ratio":1.0,"height":1500,"width":1500,"src":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/files\/a55b2717-ba38-45d3-af0f-8556bee4a24b.webp?v=1741638425"},"aspect_ratio":1.0,"height":1500,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/files\/a55b2717-ba38-45d3-af0f-8556bee4a24b.webp?v=1741638425","width":1500},{"alt":null,"id":28058608468144,"position":109,"preview_image":{"aspect_ratio":1.0,"height":1500,"width":1500,"src":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/files\/27f694b4-8961-4a2a-b9ab-b5bf7919c7e6.webp?v=1741638432"},"aspect_ratio":1.0,"height":1500,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/files\/27f694b4-8961-4a2a-b9ab-b5bf7919c7e6.webp?v=1741638432","width":1500},{"alt":null,"id":28058610041008,"position":110,"preview_image":{"aspect_ratio":1.0,"height":1500,"width":1500,"src":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/files\/291c05c6-c583-4df5-8c04-2e1f36d44f3a.webp?v=1741638440"},"aspect_ratio":1.0,"height":1500,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/files\/291c05c6-c583-4df5-8c04-2e1f36d44f3a.webp?v=1741638440","width":1500}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"29f14af005b6a36aab0617f0ee0e9027aaa08c7e","name":"Subscribe \u0026 Save","options":[{"name":"Deliver every","position":1,"values":["1 month","2 month","3 months","4 months"]}],"selling_plans":[{"id":2368831664,"name":"Every 1 month","description":null,"options":[{"name":"Deliver every","position":1,"value":"1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368864432,"name":"Every 2 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"2 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368897200,"name":"Every 3 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368929968,"name":"Every 4 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"5859381"}],"content":"\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eSlip into something effortless, award-winning, and multitasking. Slip Tint Tinted Moisturizer sheer shades provide just enough coverage to even your complexion and give you an easy, no-makeup makeup look. Powered by Saie Science, Slip Tint Tinted Moisturizer’s formula is supercharged with clean ingredients like \u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003eHyaluronic Acid to hydrate, Licorice Root Extract to visibly brighten, and 100% Mineral Non-Nano Zinc Oxide SPF 35 to protect against UVA\/UVB rays and free radical damage. \u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003eEach shade has been crafted to seamlessly blend into a wide range of skin tones and creates that hydrated, Signature SaieGlow™\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eSlip Tint is also dimethicone free, paraben free, talc free, silicone free, synthetic dye free, phthalate free, essential oil free, soy free, natural \u0026amp; synthetic fragrance-free, formulated without gluten \u0026amp; cruelty free. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp class=\"sh-color-black sh-color\"\u003e\u003cstrong style=\"font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; font-size: 0.875rem;\"\u003eGet to know these effective, luxury ingredients:\u003cspan class=\"gmail-Apple-converted-space sh-color-black sh-color\"\u003e \u003c\/span\u003e\u003c\/strong\u003e\u003c\/p\u003e\n\u003cp class=\"sh-color-black sh-color\"\u003e⁃Hyaluronic Acid deeply hydrates\u003cspan class=\"gmail-Apple-converted-space sh-color-black sh-color\"\u003e \u003cbr\u003e\u003c\/span\u003e⁃Licorice Root extract brightens and refines\u003cspan class=\"gmail-Apple-converted-space sh-color-black sh-color\"\u003e \u003cbr\u003e\u003c\/span\u003e⁃100% mineral zinc-oxide offers clean SPF protection\u003cbr\u003e⁃Pansy Flower fights free radicals and delivers antioxidants\u003cspan class=\"gmail-Apple-converted-space sh-color-black sh-color\"\u003e \u003c\/span\u003e\u003c\/p\u003e\n\u003cp class=\"sh-color-black sh-color\"\u003e\u003cspan class=\"gmail-Apple-converted-space sh-color-black sh-color\"\u003eCheck out our \u003ca href=\"https:\/\/saiehello.com\/pages\/find-your-shade\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eshade finder\u003c\/strong\u003e\u003c\/span\u003e\u003c\/a\u003e to find your match!\u003c\/span\u003e\u003c\/p\u003e\n\u003cp class=\"p1\"\u003eBest Clean Tinted Moisturizer as part of \u003cstrong data-mce-fragment=\"1\"\u003eAllure Best of Beauty, Cosmopolitan Holy Grail Awards 2021, \u003c\/strong\u003e\u003cspan class=\"s1\"\u003e\u003cstrong\u003eWomen’s Health Beauty Awards,\u003c\/strong\u003e\u003c\/span\u003e \u003cspan class=\"s1\"\u003e\u003cstrong\u003eNew Beauty Awards, \u003c\/strong\u003eand\u003c\/span\u003e \u003cspan class=\"s1\"\u003e\u003cstrong\u003eSELF Healthy Beauty Awards\u003cbr\u003e\u003cbr\u003e\u003c\/strong\u003e\u003c\/span\u003eCruelty-Free and Formulated without Gluten\u003c\/p\u003e"}
  </script>

