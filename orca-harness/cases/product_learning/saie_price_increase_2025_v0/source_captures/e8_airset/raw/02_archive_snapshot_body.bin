6b69f36ebae4f02b7d10dc7c03f18ac\/d6b69f36ebae4f02b7d10dc7c03f18ac.HD-720p-4.5Mbps-30898798.mp4?v=0","width":404},{"format":"m3u8","height":1080,"mime_type":"application\/x-mpegURL","url":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/d6b69f36ebae4f02b7d10dc7c03f18ac\/d6b69f36ebae4f02b7d10dc7c03f18ac.m3u8?v=0","width":606}]}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"29f14af005b6a36aab0617f0ee0e9027aaa08c7e","name":"Subscribe \u0026 Save","options":[{"name":"Deliver every","position":1,"values":["1 month","2 month","3 months","4 months"]}],"selling_plans":[{"id":2368831664,"name":"Every 1 month","description":null,"options":[{"name":"Deliver every","position":1,"value":"1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368864432,"name":"Every 2 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"2 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368897200,"name":"Every 3 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368929968,"name":"Every 4 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"5859381"}],"content":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eOur #1 bestseller for a reason. Glowy Super Gel™ is the easiest way to glow and your forever first step under makeup for an effortless radiance. Its non-comedogenic gel formula is lightweight, glitter-free, and supercharged with Plant-Derived Glycerin and Squalane for hydrated, brightened skin. Just apply 1-2 pumps under makeup for an instant lit-from-within look. Glowy Super Gel™ is available in four universal sheer shades. \u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eGet the Signature SaieGlow™:\u003c\/span\u003e\u003c\/p\u003e\n\u003cul\u003e\n\u003cli dir=\"ltr\"\u003e\n\u003cspan\u003eStarglow (\u003c\/span\u003e\u003cspan\u003echampagne) \u003c\/span\u003e\u003cspan\u003efor a \u003c\/span\u003e\u003cspan\u003elit-from-within glow\u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\"\u003e\n\u003cspan\u003eSunglow (bronze gold) \u003c\/span\u003e\u003cspan\u003efor a back-from-vacation glow\u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\"\u003e\n\u003cspan\u003eRoseglow (rose gold) \u003c\/span\u003e\u003cspan\u003efor an ethereal glow\u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\"\u003e\n\u003cspan\u003eNEW! Warmglow (soft warm gold) \u003c\/span\u003e\u003cspan\u003efor a candlelit glow\u003c\/span\u003e\u003cspan\u003e \u003c\/span\u003e\u003cb\u003e\u003cbr\u003e\u003c\/b\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eCruelty-Free, Gluten-Free, Non-Comedogenic and Vegan\u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cstrong\u003e\u003ca href=\"https:\/\/www.allure.com\/best-of-beauty-2024-winners#clean\"\u003eAllure - Best of Beauty 2024 - Best Clean Makeup \u003c\/a\u003e\u003cbr\u003e\u003c\/strong\u003e\u003cstrong\u003e\u003ca href=\"https:\/\/www.whowhatwear.com\/beauty\/makeup\/best-makeup-products-2024\"\u003eWho What Wear UK - 2024 Beauty NEXT Awards - Best Conscious Makeup Product\u003c\/a\u003e\u003c\/strong\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e"}
  </script>

