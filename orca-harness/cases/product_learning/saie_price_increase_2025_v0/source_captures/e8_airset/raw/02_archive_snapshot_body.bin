rchive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/e25394d0fbbd4a2091a6519e0528f776\/e25394d0fbbd4a2091a6519e0528f776.SD-480p-0.9Mbps-20669618.mp4?v=0","width":268},{"format":"mp4","height":1080,"mime_type":"video\/mp4","url":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/e25394d0fbbd4a2091a6519e0528f776\/e25394d0fbbd4a2091a6519e0528f776.HD-1080p-2.5Mbps-20669618.mp4?v=0","width":606},{"format":"mp4","height":720,"mime_type":"video\/mp4","url":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/e25394d0fbbd4a2091a6519e0528f776\/e25394d0fbbd4a2091a6519e0528f776.HD-720p-1.6Mbps-20669618.mp4?v=0","width":404},{"format":"m3u8","height":1080,"mime_type":"application\/x-mpegURL","url":"\/\/web.archive.org\/web\/20250428045316\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/e25394d0fbbd4a2091a6519e0528f776\/e25394d0fbbd4a2091a6519e0528f776.m3u8?v=0","width":606}]}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"29f14af005b6a36aab0617f0ee0e9027aaa08c7e","name":"Subscribe \u0026 Save","options":[{"name":"Deliver every","position":1,"values":["1 month","2 month","3 months","4 months"]}],"selling_plans":[{"id":2368831664,"name":"Every 1 month","description":null,"options":[{"name":"Deliver every","position":1,"value":"1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368864432,"name":"Every 2 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"2 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368897200,"name":"Every 3 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368929968,"name":"Every 4 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"5859381"}],"content":"\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003e85% skincare serum, 15% weightless pigment for 100% your best skin ever. Our lightweight skin tint foundation provides skincare benefits, medium coverage and a luminous, second-skin finish. Press in this lightweight serum formula like you would your skincare serum to get all the benefits of Glowy Super Skin’s supercharged ingredients like Hyaluronic Acid and Rice Bran Peptides for visibly plumper, more hydrated, and brighter skin. So weightless and breathable that you’ll forget you’re wearing foundation at all. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cb\u003e85% SUPERCHARGED INGREDIENTS: \u003cbr\u003e\u003c\/b\u003e\u003cb style=\"font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; font-size: 0.875rem;\"\u003eHyaluronic Acid  - \u003c\/b\u003e\u003cspan style=\"font-weight: 400;\"\u003eAttracts and binds moisture to smooth and hydrate skin\u003cbr\u003e\u003cbr\u003e\u003c\/span\u003e\u003cb style=\"font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; font-size: 0.875rem;\"\u003eRice Bran Peptides - \u003c\/b\u003e\u003cspan style=\"font-weight: 400;\"\u003eReduces the appearance of fine lines, pore, helps fade dark spots brightening skin tone.\u003cbr\u003e\u003cbr\u003e\u003c\/span\u003e\u003cb style=\"font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; font-size: 0.875rem;\"\u003ePolyglutamic Acid -\u003c\/b\u003e\u003cspan style=\"font-weight: 400;\"\u003e Hydrates the skin while locking in moisture to soften the appearance of fine lines, pores and plump the skin.\u003cbr\u003e\u003cbr\u003e\u003c\/span\u003e\u003cb style=\"font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; font-size: 0.875rem;\"\u003eGlycerin - \u003c\/b\u003e\u003cspan style=\"font-weight: 400;\"\u003eA powerful humectant known to increase skin’s natural moisture level.\u003c\/span\u003e\u003c\/p\u003e"}
