pactOpen_184672-STACK_2.jpg?v=1739984246","width":1080},{"alt":"common","id":27984958193840,"position":9,"preview_image":{"aspect_ratio":1.0,"height":1080,"width":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/powderblushbrush_0001_SuperSuede_3Quarter_Brush_Main_184629-STACK.jpg?v=1739984246"},"aspect_ratio":1.0,"height":1080,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/powderblushbrush_0001_SuperSuede_3Quarter_Brush_Main_184629-STACK.jpg?v=1739984246","width":1080},{"alt":"common","id":27984958226608,"position":10,"preview_image":{"aspect_ratio":1.0,"height":1080,"width":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/powderblushbrush_0000_SuperSuede_3Quarter_Brush_Alt_184640_2.jpg?v=1739984246"},"aspect_ratio":1.0,"height":1080,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/powderblushbrush_0000_SuperSuede_3Quarter_Brush_Alt_184640_2.jpg?v=1739984246","width":1080}],"requires_selling_plan":false,"selling_plan_groups":[],"content":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eThis sleek brush is thoughtfully designed to pair seamlessly with \u003ca href=\"www.saiehello.com\/products\/supersuede\"\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eSuperSuede™ Baked Powder Blush\u003c\/strong\u003e\u003c\/span\u003e\u003c\/a\u003e. \u003c\/span\u003e\u003cspan\u003eIts oval brush tip is tapered on each side which allows for easy product pickup and diffused application onto cheeks, without any fall out or mess. \u003c\/span\u003e\u003cspan\u003eThe slender 100% aluminum handle allows for a delicate, paintbrush-like hold. All Saie brushes are effortless to use, perfect for travel, and made to last.  \u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eAll Saie brushes are VEGAN, have CRUELTY-FREE SYNTHETIC BRISTLES and a 100% ALUMINUM HANDLE and are made in a \u003c\/span\u003e\u003ca href=\"https:\/\/www.usgbc.org\/leed\"\u003e\u003cspan\u003eLEED\u003c\/span\u003e\u003c\/a\u003e\u003cspan\u003e and \u003c\/span\u003e\u003ca href=\"https:\/\/resources.ecovadis.com\/ecovadis-solution-materials\/ecovadis-medals-and-badges\"\u003e\u003cspan\u003eEcoVadis SILVER CERTIFIED*\u003c\/span\u003e\u003c\/a\u003e\u003cspan\u003e FACILITY. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003ePro tip: Use one side of the bristles to pick up product and the other clean side to diffuse and blend out seams. \u003c\/span\u003e\u003c\/p\u003e"}
  </script>

