om\/cdn\/shop\/videos\/c\/vp\/33ff18b4b53e458fb14330d9beadd1f4\/33ff18b4b53e458fb14330d9beadd1f4.m3u8?v=0","width":608}]},{"alt":"carousel video","id":22148252827824,"position":39,"preview_image":{"aspect_ratio":0.563,"height":640,"width":360,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/products\/7a20f8a5729544e9a298507ca8f676b3.thumbnail.0000000.jpg?v=1631661180"},"aspect_ratio":0.563,"duration":25025,"media_type":"video","sources":[{"format":"mp4","height":480,"mime_type":"video\/mp4","url":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/7a20f8a5729544e9a298507ca8f676b3\/7a20f8a5729544e9a298507ca8f676b3.SD-480p-0.9Mbps.mp4?v=0","width":270},{"format":"m3u8","height":480,"mime_type":"application\/x-mpegURL","url":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/7a20f8a5729544e9a298507ca8f676b3\/7a20f8a5729544e9a298507ca8f676b3.m3u8?v=0","width":270}]}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"29f14af005b6a36aab0617f0ee0e9027aaa08c7e","name":"Subscribe \u0026 Save","options":[{"name":"Deliver every","position":1,"values":["1 month","2 month","3 months","4 months"]}],"selling_plans":[{"id":2368831664,"name":"Every 1 month","description":null,"options":[{"name":"Deliver every","position":1,"value":"1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368864432,"name":"Every 2 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"2 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368897200,"name":"Every 3 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368929968,"name":"Every 4 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"5859381"}],"content":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eA cream-balm bronzer with a natural-radiant finish that melts in for an effortless all-over bronze. Paired with \u003ca href=\"www.saiehello.com\/products\/the-big-brush\" target=\"_blank\" rel=\"noopener\"\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eThe Big Brush\u003c\/strong\u003e\u003c\/span\u003e\u003c\/a\u003e, Sun Melt’s creamy texture makes it easy to build and blend your look without overdoing it. Powered by Saie Science, Sun Melt’s formula is supercharged with ingredients like Colloidal Oatmeal to soothe and smooth, nourishing Grapeseed Oil and free-radical fighting Elderberry Extract. Available in six seamless shades of sun-kissed color.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e"}
