ive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/fa21d8200ac04723b93c81e8c0711504\/fa21d8200ac04723b93c81e8c0711504.m3u8?v=0","width":1080}]}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"29f14af005b6a36aab0617f0ee0e9027aaa08c7e","name":"Subscribe \u0026 Save","options":[{"name":"Deliver every","position":1,"values":["1 month","2 month","3 months","4 months"]}],"selling_plans":[{"id":2368831664,"name":"Every 1 month","description":null,"options":[{"name":"Deliver every","position":1,"value":"1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368864432,"name":"Every 2 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"2 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368897200,"name":"Every 3 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368929968,"name":"Every 4 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"5859381"}],"content":"\u003cp class=\"p1\"\u003eRethink everything you know about lip liner. Saie hello to Lip Liner 101™, the most foolproof, confusion free, and nourishing lip liner that makes it effortless to enhance your natural lip shape. The luxuriously creamy, soft matte formula glides on smoothly for a naturally framed or fully filled look with no tugging, tightness, feathering, or dryness—all in an elegantly understated, classic wooden pencil that minimizes excess packaging. Lip Liner 101™ comes in five versatile neutral shades that stack perfectly with your favorite gloss – like Glossybounce™ – for a timeless lip combo.\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003ePowered by Saie Science, Lip Liner 101’s formula is supercharged with Shea Butter, Jojoba Oil and Meadowfoam Oil for a comfortable, nourishing essential. Lip Liner 101 is vegan, cruelty free and safe for sensitive skin.\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e"}
  </script>

