HD-720p-1.6Mbps-20633110.mp4?v=0","width":576},{"format":"m3u8","height":1080,"mime_type":"application\/x-mpegURL","url":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/3dc2786b58a342699e2e2c48719af2c7\/3dc2786b58a342699e2e2c48719af2c7.m3u8?v=0","width":864}]}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"29f14af005b6a36aab0617f0ee0e9027aaa08c7e","name":"Subscribe \u0026 Save","options":[{"name":"Deliver every","position":1,"values":["1 month","2 month","3 months","4 months"]}],"selling_plans":[{"id":2368831664,"name":"Every 1 month","description":null,"options":[{"name":"Deliver every","position":1,"value":"1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368864432,"name":"Every 2 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"2 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368897200,"name":"Every 3 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368929968,"name":"Every 4 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"5859381"}],"content":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eThe slip of a lip oil meets the high-shine of a tinted gloss. Glossybounce\u003c\/span\u003e\u003cspan\u003e™\u003c\/span\u003e\u003cspan\u003e is our best-selling, high-shine lip gloss-oil hybrid with a plush, cushiony feel that’s never sticky or tacky. This long-lasting, vegan lip essential is supercharged with nourishing, hydrating ingredients for soft lips and your juiciest shine ever! Available in six sheer shades and three shimmer shades. Get a Glossybounce\u003c\/span\u003e\u003cspan\u003e™\u003c\/span\u003e\u003cspan\u003e \u003c\/span\u003e\u003cspan\u003efor every bag! \u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eGlossybounce™ is formulated without natural or synthetic fragrance and with a touch of natural stevia for taste. You may notice the scent of raw ingredients but this fades quickly after application\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e"}
  </script>

