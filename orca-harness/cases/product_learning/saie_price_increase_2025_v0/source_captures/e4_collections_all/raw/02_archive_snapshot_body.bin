L","url":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/videos\/c\/vp\/80593309100f4ba6a2a52aa62fca3399\/80593309100f4ba6a2a52aa62fca3399.m3u8?v=0","width":606}]},{"alt":"common","id":26892676300976,"position":44,"preview_image":{"aspect_ratio":1.0,"height":1400,"width":1400,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Saie_GlowSculpt_ArmSwatches_V1_58654d66-1d8a-4323-8465-806793c52e1d.png?v=1722871549"},"aspect_ratio":1.0,"height":1400,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Saie_GlowSculpt_ArmSwatches_V1_58654d66-1d8a-4323-8465-806793c52e1d.png?v=1722871549","width":1400}],"requires_selling_plan":false,"selling_plan_groups":[{"id":"29f14af005b6a36aab0617f0ee0e9027aaa08c7e","name":"Subscribe \u0026 Save","options":[{"name":"Deliver every","position":1,"values":["1 month","2 month","3 months","4 months"]}],"selling_plans":[{"id":2368831664,"name":"Every 1 month","description":null,"options":[{"name":"Deliver every","position":1,"value":"1 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368864432,"name":"Every 2 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"2 month"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368897200,"name":"Every 3 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"3 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}},{"id":2368929968,"name":"Every 4 months","description":null,"options":[{"name":"Deliver every","position":1,"value":"4 months"}],"recurring_deliveries":true,"price_adjustments":[{"order_count":null,"position":1,"value_type":"percentage","value":10}],"checkout_charge":{"value_type":"percentage","value":100}}],"app_id":"5859381"}],"content":"\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eThe flush of blush meets a radiant \u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003eglow\u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003e. Glow Sculpt is a creamy, tinted highlighter that gives an unparalleled “\u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003elifted” effect that’s never chalky or glittery. Its lightweight formula moisturizes and nourishes skin while diffused cream pigments blend with fine micropearl to create the ultimate multi-tasking \u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003eSaieGlow\u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003e™ \u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003eessential. Going for a glowy blush? Seeking out a sculpting highlighter? Get ready for the Glow Sculpt effect. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eFinished your Glow Sculpt? Glow forth with our refillable compact! When you’re done, pop out the old shade pan and replace with a glowy, new one. Our 100% plastic-free shade pans help us reduce single-use plastic and help you keep on glowing. Win-win! \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003ci\u003e\u003cspan style=\"font-weight: 400;\"\u003eBy choosing to refill you’re saving one less compact from landfills and supporting innovation in beauty sustainability! 🌱 \u003c\/span\u003e\u003c\/i\u003e\u003c\/p\u003e"}
  </script>

