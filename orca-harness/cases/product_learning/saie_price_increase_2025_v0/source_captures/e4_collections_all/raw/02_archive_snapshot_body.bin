<div class="product-grid-item js-product-wrapper js-grid-product " data-title="The Matcha Tin" data-price="38.00" data-variant="44347895349424" data-product-handle="matcha-tin">

  
  <script type="application/json" class="js-product-data" data-id="7828393197744" data-handle="matcha-tin">
    {"id":7828393197744,"title":"The Matcha Tin","handle":"matcha-tin","description":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eA 20g tin of limited-edition rocky’s matcha x Saie unique matcha blend produced by Horii Shichimeien in Uji, Japan. This custom-crafted, ceremonial blend boasts a vibrant green color and silky texture making it an ideal choice for those new to matcha. Each order will receive a \u003cstrong\u003eFREE Deluxe 5mL Glowy Super Gel™ (Warmglow)\u003c\/strong\u003e to complete your daily glow ritual. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003erocky’s matcha is a cult-favorite LA-based tea company specializing in ceremonial grade matcha. They source conventional and organic matcha, blends and single cultivars, from the world’s leading regions for tea harvesting, primarily located throughout Japanese prefectures. \u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003e*All sales are final, while supplies last. One per customer.\u003c\/span\u003e\u003c\/p\u003e","published_at":"2025-04-24T11:00:07-04:00","created_at":"2025-04-08T22:11:08-04:00","vendor":"Saie","type":"Finished Good","tags":["badge:new","gift","merch","new"],"price":3800,"price_min":3800,"price_max":3800,"available":false,"price_varies":false,"compare_at_price":null,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":44347895349424,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"RMXSB","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"name":"The Matcha Tin","public_title":null,"options":["Default Title"],"price":3800,"weight":0,"compare_at_price":null,"inventory_management":"shopify","barcode":"810029483773","requires_selling_plan":false,"selling_plan_allocations":[],"quantity_rule":{"min":1,"max":null,"increment":1}}],"images":["\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.