<div class="product-grid-item js-product-wrapper js-grid-product " data-title="The Saie Water Bottle" data-price="18.00" data-variant="44361221144752" data-product-handle="the-saie-water-bottle">

  
  <script type="application/json" class="js-product-data" data-id="7374850097328" data-handle="the-saie-water-bottle">
    {"id":7374850097328,"title":"The Saie Water Bottle","handle":"the-saie-water-bottle","description":"\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eThe secret to getting a dewy SaieGlow™ from the inside out– Hydrate sustainably with The Saie Water Bottle. Made from 50% PCR and BPA\/BPS-free plastic, this durable 32oz water bottle features a tethered cap and comfy narrow mouth for whatever adventures you have planned. Our Saie Water Bottle is also phthalate-free, stain-and odor-resistant, dishwasher safe, leak proof and made in the USA. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003eThis bottle saves the equivalent of 8 single-use plastic bottles from landfills. Drink out of it for a year and you’ll have saved 167 single-use bottles from landfills. Not bad right?\u003cbr\u003e\u003c\/p\u003e\n\u003cdiv class=\"sh-color-black sh-color\"\u003e\u003c\/div\u003e","published_at":"2024-02-20T15:53:13-05:00","created_at":"2023-09-18T17:26:35-04:00","vendor":"Saie","type":"Merch","tags":["gifts","merch","tyb"],"price":1800,"price_min":1800,"price_max":1800,"available":false,"price_varies":false,"compare_at_price":null,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":44361221144752,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"WTRBTL-1","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"name":"The Saie Water Bottle","public_title":null,"options":["Default Title"],"price":1800,"weight":907,"compare_at_price":null,"inventory_management":"shopify","barcode":"810029482134","requires_selling_plan":false,"selling_plan_allocations":[],"quantity_rule":{"min":1,"max":null,"increment":1}}],"images":["\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/saie-nalgene-water-bottle-featured.png?v=1695073693","\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/saie-water-bottle-feature-2.png?