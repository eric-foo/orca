<div class="product-grid-item js-product-wrapper js-grid-product " data-title="Glowy Super Gel" data-price="28.00" data-variant="43725800636592" data-product-handle="glowy-super-gel-luminizer">

  
  <script type="application/json" class="js-product-data" data-id="4455329759292" data-handle="glowy-super-gel-luminizer">
    {"id":4455329759292,"title":"Glowy Super Gel","handle":"glowy-super-gel-luminizer","description":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eOur #1 bestseller for a reason. Glowy Super Gel™ is the easiest way to glow and your forever first step under makeup for an effortless radiance. Its non-comedogenic gel formula is lightweight, glitter-free, and supercharged with Plant-Derived Glycerin and Squalane for hydrated, brightened skin. Just apply 1-2 pumps under makeup for an instant lit-from-within look. Glowy Super Gel™ is available in four universal sheer shades. \u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eGet the Signature SaieGlow™:\u003c\/span\u003e\u003c\/p\u003e\n\u003cul\u003e\n\u003cli dir=\"ltr\"\u003e\n\u003cspan\u003eStarglow (\u003c\/span\u003e\u003cspan\u003echampagne) \u003c\/span\u003e\u003cspan\u003efor a \u003c\/span\u003e\u003cspan\u003elit-from-within glow\u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\"\u003e\n\u003cspan\u003eSunglow (bronze gold) \u003c\/span\u003e\u003cspan\u003efor a back-from-vacation glow\u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\"\u003e\n\u003cspan\u003eRoseglow (rose gold) \u003c\/span\u003e\u003cspan\u003efor an ethereal glow\u003c\/span\u003e\n\u003c\/li\u003e\n\u003cli dir=\"ltr\"\u003e\n\u003cspan\u003eNEW! Warmglow (soft warm gold) \u003c\/span\u003e\u003cspan\u003efor a candlelit glow\u003c\/span\u003e\u003cspan\u003e \u003c\/span\u003e\u003cb\u003e\u003cbr\u003e\u003c\/b\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eCruelty-Free, Gluten-Free, Non-Comedogenic and Vegan\u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cstrong\u003e\u003ca href=\"https:\/\/www.allure.com\/best-of-beauty-2024-winners#clean\"\u003eAllure - Best of Beauty 2024 - Best Clean Makeup \u003c\/a\u003e\u003cbr\u003e\u003c\/strong\u003e\u003cstrong\u003e\u003ca href=\"https:\/\/www.whowhatwear.com\/beauty\/makeup\/best-makeup-products-2024\"\u003eWho What Wear UK - 2024 Beauty NEXT Awards - Best Conscious Makeup Product\u003c\/a\u003e\u003c\/strong\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e","published_at":"2020-02-12T07:03:27-05:00","created_at":"2020-02-07T11:17:19-05:00","vendor":"Saiehello","type":"","tags":["allure-2024","badge:allure-2024","bestseller","bronzing","bronzing drops","dimethicone-free","dry-skin","dullness","essential oil-free","face","formulated-without-gluten","fragrance-free","glamour-2023","hyperpigmentation","multi-use","oily-skin","soy-free","squalane","star glow","starglow","Subscription","subscriptions","sun glow","sunglow","tyb","vegan","vitamin-c"],"price":2800,"price_min":2800,"price_max":2800,"available":true,"price_varies":false,"compare_at_price":null,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":43725800636592,"title":"Roseglow","option1":"Roseglow","option2":null,"option3":null,"sku":"SGSG080GBL","requires_shipping":true,"taxable":true,"featured_image":{"id":34278899581104,"product_id":4455329759292,"position":5,"created_at":"2024-06-18T19:23:51-04:00","updated_at":"2024-12-16T13:21:46-05:00","alt":null,"width":1080,"height":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/roseglow-hero.jpg?v=1734373306","variant_ids":[43725800636592]},"available":true,"name":"Glowy Super Gel - Roseglow","public_title":"Roseglow","options":["Roseglow"],"price":2800,"weight":45,"compare_at_price":null,"inventory_management":"shopify","barcode":"810029482769","featured_media":{"alt":null,"id":26655012978864,"position":5,"preview_image":{"aspect_ratio":1.0,"height":1080,"width":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/roseglow-hero.jpg?v=1734373306"}},"requires_selling_plan":false,"selling_plan_allocations":[{"price_adjustments":[{"position":1,"price":2520}],"price":