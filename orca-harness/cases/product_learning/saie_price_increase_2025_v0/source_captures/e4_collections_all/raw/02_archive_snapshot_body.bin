  <script type="application/json" class="js-product-data" data-id="7792515023024" data-handle="the-supersuede-stack">
    {"id":7792515023024,"title":"The SuperSuede™ Stack","handle":"the-supersuede-stack","description":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eThoughtfully designed to pair seamlessly together, SuperSuede™ Baked Powder Blush and The Powder Blush Brush are the perfect duo for a diffused \u003c\/span\u003e\u003cspan\u003eflush of color\u003c\/span\u003e\u003cspan\u003e. Start by dipping the flat side of The Powder Blush Brush into SuperSuede™. Gently tap off excess pigment from bristles for a controlled, even application. Finish by softly sweeping brush over apples of the cheeks and up toward the temples. Repeat to build pigment. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e","published_at":"2025-02-22T08:58:01-05:00","created_at":"2025-02-20T08:13:30-05:00","vendor":"Saie","type":"Finished Good","tags":["brush","bundles","cheek","kits","new"],"price":5000,"price_min":5000,"price_max":5000,"available":true,"price_varies":false,"compare_at_price":null,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":44224395444400,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"SSATB","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"name":"The SuperSuede™ Stack","public_title":null,"options":["Default Title"],"price":5000,"weight":0,"compare_at_price":null,"inventory_management":null,"barcode":null,"requires_selling_plan":false,"selling_plan_allocations":[],"quantity_rule":{"min":1,"max":null,"increment":1}}],"images":["\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/supersuedestack.png?v=1740231927","\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Group_12.png?v=1740231927","\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/0001_SuperSuede_Brush_Main_184363-STACKcopy4.jpg?v=1740231927","\/\/web.archive.org\/web\/20250428061256\/https:\/\/s