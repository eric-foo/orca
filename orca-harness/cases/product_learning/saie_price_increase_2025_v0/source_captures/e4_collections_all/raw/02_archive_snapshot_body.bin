  <script type="application/json" class="js-product-data" data-id="7148053201072" data-handle="lip-blur">
    {"id":7148053201072,"title":"Lip Blur","handle":"lip-blur","description":"\u003cstyle type=\"text\/css\"\u003e\u003c!--\ntd {border: 1px solid #cccccc;}br {mso-data-placement:same-cell;}\n--\u003e\u003c\/style\u003e\n\u003cp class=\"p1\"\u003e\u003cspan data-sheets-userformat='{\"2\":769,\"3\":{\"1\":0},\"11\":4,\"12\":0}' data-sheets-value=\"{\u0026quot;1\u0026quot;:2,\u0026quot;2\u0026quot;:\u0026quot;A clean matte lipstick done the Saie way. It's longwearing, shine-free, and hydrating. Lip Blur is packed with a blend of nourishing ingredients including Hyaluronic Acid, Olive Oil, Jojoba Esters, and Berry Fruit Wax to condition lips and blend in seamlessly. All six shades are formulated to be super comfortable, buildable, and achieve a softly-blurred to full coverage matte finish.\u0026quot;}\"\u003eA clean matte lipstick done the Saie way. It's longwearing, shine-free, and hydrating. Lip Blur is packed with a blend of nourishing ingredients including Hyaluronic Acid, Olive Oil, Jojoba Esters, and Berry Fruit Wax to condition lips and blend in seamlessly. All six shades are formulated to be super comfortable, buildable, and achieve a softly-blurred to full coverage matte finish.\u003c\/span\u003e\u003cbr\u003e\u003c\/p\u003e","published_at":"2025-04-25T11:32:36-04:00","created_at":"2022-07-25T18:09:50-04:00","vendor":"Saie","type":"","tags":["dry-skin","hyaluronic acid","lip","lips","Shade Finder","tyb"],"price":2400,"price_min":2400,"price_max":2400,"available":true,"price_varies":false,"compare_at_price":0,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":41826213331120,"title":"Modern","option1":"Modern","option2":null,"option3":null,"sku":"BLUR010GBL","requires_shipping":true,"taxable":true,"featured_image":{"id":33436520906928,"product_id":7148053201072,"position":46,"created_at":"2023-11-14T15:17:46-05:00","updated_at":"2023-11-14T15:17:46-05:00","alt":null,"width":1080,"height":1080,"src":"\/\/web.archiv