  <script type="application/json" class="js-product-data" data-id="7788378816688" data-handle="saieglow-starter-kit">
    {"id":7788378816688,"title":"SaieGlow Starter Kit","handle":"saieglow-starter-kit","description":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eEverything you need to start your very own SaieGlow™ in style. Hydrate and highlight with Glowy Super Gel in NEW! Roseglow, add a touch of natural flush with Dew Blush in Baby, and get a glossy, juicy lip with Glossybounce™ in Play. Head out with these essentials in your chic jelly bag for a guaranteed glowy day!\u003cbr\u003e\u003cbr\u003e\u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eSHADE DESCRIPTIONS\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eDew Blush in Baby (baby pink) - full size \u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eGlossybounce™ in Play (bright pink) - full size\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eGlowy Super Gel in Roseglow (rose gold glow) - mini 15mL\u003cbr\u003e\u003c\/span\u003e\u003cspan\u003eLilac jelly 'birkin' bag\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e","published_at":"2025-02-27T03:00:02-05:00","created_at":"2025-02-13T16:59:46-05:00","vendor":"Saie","type":"Finished Good","tags":["new"],"price":4500,"price_min":4500,"price_max":4500,"available":true,"price_varies":false,"compare_at_price":null,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":44211465945264,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"25INTROKIT","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"name":"SaieGlow Starter Kit","public_title":null,"options":["Default Title"],"price":4500,"weight":0,"compare_at_price":null,"inventory_management":"shopify","barcode":"810029483087","requires_selling_plan":false,"selling_plan_allocations":[],"quantity_rule":{"min":1,"max":null,"increment":1}}],"images":["\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/saieglowkit.png?v=1739624347","\/