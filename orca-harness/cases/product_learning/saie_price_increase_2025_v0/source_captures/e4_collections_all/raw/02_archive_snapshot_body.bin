<div class="product-grid-item js-product-wrapper js-grid-product " data-title="Glow Sculpt" data-price="28.00" data-variant="42648794267824" data-product-handle="glow-sculpt">

  
  <script type="application/json" class="js-product-data" data-id="7331723083952" data-handle="glow-sculpt">
    {"id":7331723083952,"title":"Glow Sculpt","handle":"glow-sculpt","description":"\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eThe flush of blush meets a radiant \u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003eglow\u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003e. Glow Sculpt is a creamy, tinted highlighter that gives an unparalleled “\u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003elifted” effect that’s never chalky or glittery. Its lightweight formula moisturizes and nourishes skin while diffused cream pigments blend with fine micropearl to create the ultimate multi-tasking \u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003eSaieGlow\u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003e™ \u003c\/span\u003e\u003cspan style=\"font-weight: 400;\"\u003eessential. Going for a glowy blush? Seeking out a sculpting highlighter? Get ready for the Glow Sculpt effect. \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eFinished your Glow Sculpt? Glow forth with our refillable compact! When you’re done, pop out the old shade pan and replace with a glowy, new one. Our 100% plastic-free shade pans help us reduce single-use plastic and help you keep on glowing. Win-win! \u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003ci\u003e\u003cspan style=\"font-weight: 400;\"\u003eBy choosing to refill you’re saving one less compact from landfills and supporting innovation in beauty sustainability! 🌱 \u003c\/span\u003e\u003c\/i\u003e\u003c\/p\u003e","published_at":"2023-05-18T06:53:30-04:00","created_at":"2023-05-02T19:55:30-04:00","vendor":"Saie","type":"","tags":["allure-2024","allure-clean-2023","badge:allure-2024","cheek","cruelty-free","dimethicone-free","dry-skin","dullness","essential oil-free","face","fragrance-free","hyperpigmentation","Shade Finder","synthetic-dye-free","tyb","vegan","Verishop"],"price":2000,"price_min":2000,"price_max":2800,"available":true,"price_v