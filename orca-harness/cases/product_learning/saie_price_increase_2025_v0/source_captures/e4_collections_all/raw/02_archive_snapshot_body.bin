ps:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle2_1d31886d-9500-48ba-99be-010e30230613.jpg?v=1744822098","width":1080},{"alt":"common","id":28274123243696,"position":3,"preview_image":{"aspect_ratio":1.0,"height":1080,"width":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle1_3149c5d1-5de8-4f04-bfa2-72d47772a3d2.jpg?v=1744822098"},"aspect_ratio":1.0,"height":1080,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle1_3149c5d1-5de8-4f04-bfa2-72d47772a3d2.jpg?v=1744822098","width":1080},{"alt":"common","id":28274123374768,"position":4,"preview_image":{"aspect_ratio":1.0,"height":1080,"width":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle2_ef945eb4-7dc4-42be-914e-b79db487e8fd.jpg?v=1744822104"},"aspect_ratio":1.0,"height":1080,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle2_ef945eb4-7dc4-42be-914e-b79db487e8fd.jpg?v=1744822104","width":1080},{"alt":"common","id":28303336210608,"position":5,"preview_image":{"aspect_ratio":1.0,"height":1080,"width":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rockys.jpg?v=1745424003"},"aspect_ratio":1.0,"height":1080,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rockys.jpg?v=1745424003","width":1080},{"alt":"common","id":28274123440304,"position":6,"preview_image":{"aspect_ratio":1.0,"height":1080,"width":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle5_a4f2d511-9da7-41a4-a63f-587c9d1deec7.jpg?v=1745424003"},"aspect_ratio":1.0,"height":1080,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle5_a4f2d511-9da7-41a4-a63f-587c9d1deec7.jpg?v=1745424003","width":1080},{"alt":"common","id":28274123473072,"position":7,"preview_image":{"aspect_ratio":1.0,"height":1080,"width":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle7.jpg?v=1745424003"},"aspect_ratio":1.0,"height":1080,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle7.jpg?v=1745424003","width":1080},{"alt":"common","id":28274106400944,"position":8,"preview_image":{"aspect_ratio":1.0,"height":1080,"width":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle_3.jpg?v=1745424003"},"aspect_ratio":1.0,"height":1080,"media_type":"image","src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/Rectangle_3.jpg?v=1745424003","width":1080}],"requires_selling_plan":false,"selling_plan_groups":[],"content":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eYour forever first steps – two simple essentials designed to elevate your daily routine. Start every day effortlessly with our limited-edition rocky’s matcha x Saie matcha blend–this kit contains everything you need to brew the perfect cup. Complete your routine with our bestselling Glowy Super Gel™ illuminator for a lit-from-within glow. \u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003erocky’s matcha for Saie Ceremonial Blend Matcha is a custom-crafted blend produced by Horii Shichimeien in Uji, Japan. \u003c\/span\u003e\u003cb\u003e\u003c\/b\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eThis Essential Kit includes: \u003c\/span\u003e\u003c\/p\u003e\n\u003cul\u003e\n\u003cli aria-level=\"1\" dir=\"ltr\"\u003e\n\u003cp role=\"presentation\" dir=\"ltr\"\u003e\u003cspan\u003eFull-size \u003ca rel=\"noopener\" href=\"https:\/\/www.saiehello.com\/products\/glowy-super-gel-luminizer\" target=\"_blank\"\u003e\u003cspan style=\"text-decoration: underline;\"\u003e\u003cstrong\u003eGlowy Super Gel™\u003c\/strong\u003e\u003c\/span\u003e\u003c\/a\u003e in Warmglow\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli aria-level=\"1\" dir=\"ltr\"\u003e\n\u003cp role=\"presentation\" dir=\"ltr\"\u003e\u003cspan\u003erocky’s matcha for Saie Ceremonial Blend Matcha Tin - 20g\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli aria-level=\"1\" dir=\"ltr\"\u003e\n\u003cp role=\"presentation\" dir=\"ltr\"\u003e\u003cspan\u003eSaie x rocky’s matcha Limited-Edition Whisk Stand \u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli aria-level=\"1\" dir=\"ltr\"\u003e\n\u003cp role=\"presentation\" dir=\"ltr\"\u003e\u003cspan\u003erocky’s matcha Whisk\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli aria-level=\"1\" dir=\"ltr\"\u003e\n\u003cp role=\"presentation\" dir=\"ltr\"\u003e\u003cspan\u003erocky’s matcha Sifter Tea Strainer\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003cli aria-level=\"1\" dir=\"ltr\"\u003e\n\u003cp role=\"presentation\" dir=\"ltr\"\u003e\u003cspan\u003erocky's matcha Measuring Spoon\u003c\/span\u003e\u003c\/p\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003cp\u003e\u003cmeta charset=\"utf-8\"\u003e\u003cmeta charset=\"utf-8\"\u003erocky’s matcha is a cult-favorite LA-based tea company specializing in ceremonial grade matcha. They source conventional and organic matcha, blends and single cultivars, from the world’s leading regions for tea harvesting, primarily located throughout Japanese prefectures.\u003cbr\u003e\u003cbr\u003e\u003cmeta charset=\"utf-8\"\u003e\u003cspan\u003e*All sales are final, while supplies last. One per customer.\u003c\/span\u003e\u003cbr\u003e\u003c\/p\u003e"}
  </script>

