  <script type="application/json" class="js-product-data" data-id="7362040332464" data-handle="glossybounce">
    {"id":7362040332464,"title":"Glossybounce™","handle":"glossybounce","description":"\u003cp dir=\"ltr\"\u003e\u003cspan\u003eThe slip of a lip oil meets the high-shine of a tinted gloss. Glossybounce\u003c\/span\u003e\u003cspan\u003e™\u003c\/span\u003e\u003cspan\u003e is our best-selling, high-shine lip gloss-oil hybrid with a plush, cushiony feel that’s never sticky or tacky. This long-lasting, vegan lip essential is supercharged with nourishing, hydrating ingredients for soft lips and your juiciest shine ever! Available in six sheer shades and three shimmer shades. Get a Glossybounce\u003c\/span\u003e\u003cspan\u003e™\u003c\/span\u003e\u003cspan\u003e \u003c\/span\u003e\u003cspan\u003efor every bag! \u003c\/span\u003e\u003c\/p\u003e\n\u003cp dir=\"ltr\"\u003e\u003cspan\u003eGlossybounce™ is formulated without natural or synthetic fragrance and with a touch of natural stevia for taste. You may notice the scent of raw ingredients but this fades quickly after application\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e","published_at":"2023-08-22T16:29:41-04:00","created_at":"2023-08-16T17:45:45-04:00","vendor":"Saie","type":"","tags":["badge:new","cruelty-free","dullness","lip","lips","new","Shade Finder","Subscription","tyb","vegan","Verishop"],"price":2200,"price_min":2200,"price_max":2200,"available":true,"price_varies":false,"compare_at_price":null,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":43879455981744,"title":"Remix","option1":"Remix","option2":null,"option3":null,"sku":"07GLOSS05A","requires_shipping":true,"taxable":true,"featured_image":{"id":34725321474224,"product_id":7362040332464,"position":10,"created_at":"2024-09-01T11:33:33-04:00","updated_at":"2024-09-01T11:33:36-04:00","alt":"remix","width":1080,"height":1080,"src":"\/\/web.archive.org\/web\/20250428061256\/https:\/\/saiehello.com\/cdn\/shop\/files\/new-_0011_Saie_Glossybounce_Silo_Remix.jpg?v=1725204816","variant_ids":[438