  <div class="cart-items" rv-hide="cart.item_count | lt 1">
    <div class="item" rv-each-item="cart.subscription_items.items">
  <a class="item-image" rv-href="item.original_product.url">
    <img rv-src="item.line_item.image | productImageSize '130x'" rv-alt="item.original_product.title">
  </a>
  <div class="item-right">
    <div class="item-text">
      <div class="item-main">
        <a class="item-title">
          <span class="fakt-heading-bold" rv-href="item.line_item.url">
            { item.original_product.title }
          </span>
          <span class="fakt-heading" rv-href="item.line_item.url" rv-if="item.line_item.variant_title"> — { item.line_item.variant_title } </span>
        </a>

