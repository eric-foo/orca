    <script type="text/javascript">
  // if survey was started already...
  if(localStorage.getItem("surveyStatus") && localStorage.getItem("surveyStatus") != "") {
    var surveyStatus = JSON.parse(localStorage.getItem("surveyStatus"));

    if(surveyStatus.completed == true) {
      $(".js-survey-show").addClass("hide");
      $(".js-survey-update-href").map(function() {
          $(this).attr("href", $(this).attr("href") + "?survey=results");
        });
    } else {
      // have they answered questions?
      for (var sectionAnswers in surveyStatus.quizSections) {
        if (surveyStatus.quizSections.hasOwnProperty(sectionAnswers)) {
          for(var i = 0; i < surveyStatus.quizSections[sectionAnswers].length; i++) {
            if(surveyStatus.quizSections[sectionAnswers][i] != undefined) {
              if(surveyStatus.quizSections[sectionAnswers][i].length != 0) {
                surveyStatus.completed = "questions";
              }
            }
          }
        }
      }

      if(surveyStatus.completed != "questions") {
        // have they answered the profile questions?
        for (var profileAnswers in surveyStatus.profile) {
          if (surveyStatus.profile.hasOwnProperty(profileAnswers)) {
            if(surveyStatus.quizSections[profileAnswers] != "") {
              surveyStatus.completed = "profile";
            }
          }
        }
      }

      if(surveyStatus.completed != false) {
        $(".js-survey-update-href, .js-survey-show").map(function() {
          $(this).attr("href", $(this).attr("href") + "?survey=" + surveyStatus.completed);
        });
      }

      $(".js-survey-show").removeClass("hide");
    }
  }
</script>
  
