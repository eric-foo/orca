        </div>
      </div>
      <div class="item-numbers">
        <a href="#" rv-data-cart-update-id="item.line_item.variant_id" rv-data-cart-quantity="item.line_item.quantity | minus 1">-</a>
        <div class="item-quantity">{ item.line_item.quantity }</div>
        <a href="#" rv-data-cart-update-id="item.line_item.variant_id" rv-data-cart-quantity="item.line_item.quantity | plus 1">+</a>
      </div>
    </div>

    <div class="item-price">{ item.line_item.line_price | money }</div>

