    <div id="shopify-section-cart-shared" class="shopify-section cart-body">

<div class="cart-half empty" rv-if="cart.item_count | lt 1">
  <div class="cart-empty" rv-data-count="cart.item_count">
  <div class="empty-state-text">Your cart is currently empty.</div>
</div>
</div>


<div class="cart-half plan" rv-unless="cart.subscription_items.items | empty">
  <div class="cart-contents">

  <div class="cart-title">Your Plan</div>

  <div class="cart-items" rv-hide="cart.item_count | lt 1">
    <div class="item" rv-each-item="cart.subscription_items.items">
  <a class="item-image" rv-href="item.original_product.url">
    <img rv-src="item.line_item.image | productImageSize '130x'" rv-alt="item.original_product.title">
  </a>
  <div class="item-right">
    <div class="item-text">
      <div class="item-main">
        <a class="item-title">
          <span class="fakt-heading-bold" rv-href="item.line_item.url">
            { item.original_product.title }
          </span>
          <span class="fakt-heading" rv-href="item.line_item.url" rv-if="item.line_item.variant_title"> — { item.line_item.variant_title } </span>
        </a>

        <div href="#" class="item-frequency item-subtitle">
          Every <span rv-if="item.line_item.properties.shipping_interval_frequency | int | gt 1">{ item.line_item.properties.shipping_interval_frequency | int}</span> {  item.line_item.properties.shipping_interval_unit_type | slice 0 -1 }<span rv-if="item.line_item.properties.shipping_interval_frequency | int | gt 1">s</span>
        </div>
      </div>
      <div class="item-numbers">
