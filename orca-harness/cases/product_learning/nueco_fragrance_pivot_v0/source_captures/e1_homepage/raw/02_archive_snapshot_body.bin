  <div class="transparent-overlay js-cart-hide"></div>
  <div class="modal" data-cart-view="data-cart-view">
    <a href="#" class="close-button cart-circle js-cart-hide">
      <svg viewport="0 0 13 13" version="1.1" width="13px" height="13px" xmlns="http://www.w3.org/2000/svg">
    <line x1="0" y1="13" x2="13" y2="0" stroke="black" stroke-width="1"/>
