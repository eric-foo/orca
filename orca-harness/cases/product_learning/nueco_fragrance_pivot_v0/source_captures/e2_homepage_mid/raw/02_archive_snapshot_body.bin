			var reChargeShowButton = function($) {
				$('form[action^="/cart"] [type="submit"]').prop('disabled', false);
			}
			var reChargeCartFooterJS = function($) {
				function reChargeGetCookie(name) {
					return (document.cookie.match('(^|; )' + name + '=([^;]*)')||0)[2];
				}
				function reChargeReDirection(redirect_url) {
					// Re-direct customer to desired URL
					window.location.href = redirect_url;
				}
				function reChargeBuildCheckoutURL() {
					// Build the Checkout URL
					var myshopify_domain = 'the-nue-co.myshopify.com';
					var token = reChargeGetCookie('cart');
					try {
						// Cross-domain tracking with Google Analytics
						var ga_linker = ga.getAll()[0].get('linkerParam');
					} catch (e) {
						// 'ga' is not available
						var ga_linker = '';
					}
					// Customer email address for use in the Checkout URL
					var customer_param = '';
					var checkout_url = 'https://web.archive.org/web/20190626095434/https://checkout.rechargeapps.com/r/checkout?myshopify_domain=' + myshopify_domain + '&cart_token=' + token + '&' + ga_linker + '&' + customer_param
