# Creator profile source-input hashes are recorded over LF repo-text bytes.
# Keep the checked-in JSON sources stable across Windows and CI without making
# this a general hash-framework decision.
orca/product/spines/capture/core/source_families/social_media/**/*.json text eol=lf
docs/review-inputs/youtube_shorts_fragrance_retained_recapture_v0.json text eol=lf
docs/review-inputs/youtube_shorts_fragrance_replacement_capture_v0.json text eol=lf
docs/review-inputs/youtube_shorts_fragrance_tone_expansion30_capture_v0.json text eol=lf
docs/review-inputs/youtube_shorts_fragrance_tone_expansion100_capture_v0.json text eol=lf
docs/review-inputs/youtube_shorts_fragrance_tone_expansion200_capture_v0.json text eol=lf
docs/review-inputs/creator_metric_source_live_probe_youtube_v0.json text eol=lf

# Source Capture packets are byte-faithful evidence: the manifest's recorded
# sha256 for each preserved raw file must match the raw bytes on every platform
# and every checkout. Disable all line-ending normalization for capture packets
# so autocrlf (true on Windows) cannot CRLF-inflate the archived bodies/metadata
# and break that sha256 == bytes invariant. Applies to existing and future cases.
**/source_captures/** -text
