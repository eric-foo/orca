{
  "extraKnownMarketplaces": {
    "agent-workflow-local": {
      "source": {
        "source": "file",
        "path": "../agent-workflow/marketplace.json"
      }
    }
  },
  "enabledPlugins": {
  "agent-workflow@agent-workflow-local": true,
  "anthropic-skills@inline": false,
  "cowork-plugin-management@inline": false
},
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/guard_protected_actions.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/remind_sci.py\" --hook",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_retrieval_header.py\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_repo_map_freshness.py\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_placement.py\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_prompt_provenance.py\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_search_surface_google_route.py\" --hook",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_shared_files_dirty.py\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_token_burn.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/session_context_capsule.py\" --hook",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
  "allow": [
    "Bash(git commit*)",
    "PowerShell(git commit*)",
    "Bash(git fetch origin)",
    "Bash(git fetch origin *)",
    "PowerShell(git fetch origin)",
    "PowerShell(git fetch origin *)",
    "PowerShell(git status *)",
    "PowerShell(git log *)",
    "PowerShell(git diff *)",
    "PowerShell(git show *)",
    "PowerShell(git rev-parse *)",
    "Bash(gh pr view *)",
    "Bash(gh pr checks *)",
    "Bash(gh pr diff *)",
    "Bash(gh pr list *)",
    "PowerShell(gh pr view *)",
    "PowerShell(gh pr checks *)",
    "PowerShell(gh pr diff *)",
    "PowerShell(gh pr list *)",
    "PowerShell(python .agents/hooks/check_silver_lane_registry.py *)"
  ],
  "ask": [
    "Bash(git push*)",
    "PowerShell(git push*)",
    "Bash(git remote*)",
    "PowerShell(git remote*)",
    "Bash(gh pr create*)",
    "Bash(gh pr merge*)",
    "Bash(gh pr comment*)",
    "Bash(gh pr edit*)",
    "Bash(gh pr close*)",
    "Bash(gh pr ready*)",
    "Bash(gh pr review*)",
    "PowerShell(gh pr create*)",
    "PowerShell(gh pr merge*)",
    "PowerShell(gh pr comment*)",
    "PowerShell(gh pr edit*)",
    "PowerShell(gh pr close*)",
    "PowerShell(gh pr ready*)",
    "PowerShell(gh pr review*)",
    "Bash(git reset --hard*)",
    "PowerShell(git reset --hard*)",
    "Bash(git clean*)",
    "PowerShell(git clean*)"
  ]
  }
}
