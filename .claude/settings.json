{
  "extraKnownMarketplaces": {
    "agent-workflow-local": {
      "source": {
        "source": "file",
        "path": "../agent-workflow/marketplace.json"
      }
    }
  },
  "enabledPlugins": {
    "agent-workflow@agent-workflow-local": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/guard_protected_actions.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_retrieval_header.py\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_repo_map_freshness.py\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_placement.py\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_prompt_provenance.py\" --hook",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_shared_files_dirty.py\" --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/check_token_burn.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.agents/hooks/session_context_capsule.py\" --hook",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git commit*)",
      "PowerShell(git commit*)"
    ],
    "ask": [
      "Bash(git push*)",
      "PowerShell(git push*)",
      "Bash(git remote*)",
      "PowerShell(git remote*)",
      "Bash(gh pr*)",
      "PowerShell(gh pr*)",
      "Bash(git reset --hard*)",
      "PowerShell(git reset --hard*)",
      "Bash(git clean*)",
      "PowerShell(git clean*)"
    ]
  }
}
